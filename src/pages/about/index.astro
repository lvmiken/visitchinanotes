---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

const promises = [
  "Route advice before attraction overload.",
  "Clear English for first-time visitors.",
  "Independent judgment before any partner handoff.",
];

const nonPromises = [
  "This is not a full custom tour agency site.",
  "This site does not replace visa, airline, rail, or hotel official rules.",
  "A partner introduction only happens when the traveler asks for human booking support.",
];

const deskTypes = [
  {
    title: "City editorial desks",
    description: "City desks focus on local route shape, districts, hotel areas, and the places that genuinely change how a visit feels.",
  },
  {
    title: "Route planning desk",
    description: "National route, itinerary, and city-comparison pieces are handled separately so broader trip design stays coherent.",
  },
  {
    title: "Transport and payments desk",
    description: "Airport, rail, payment, and booking-basics pages stay with a desk focused on the mechanics of travel rather than destination storytelling.",
  },
  {
    title: "Travel readiness desk",
    description: "App setup, packing, daily-use prep, and other first-trip basics live with a desk focused on lowering friction before departure.",
  },
  {
    title: "Entry and visa desk",
    description: "Transit eligibility, re-entry logic, and entry prep are handled with official confirmation treated as part of the work, not an afterthought.",
  },
  {
    title: "Family travel desk",
    description: "Family pages focus on pace, age fit, and whether a plan still works once children change the shape of the day.",
  },
];
---

<BaseLayout
  title="About China Travel Notes | What This Site Is For"
  description="Learn who China Travel Notes is for, how to use the site, and what kind of trip-planning help it does and does not provide."
  showAds={false}
>
  <section class="split-hero">
    <article class="hero article">
      <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "About" }]} />
      <p class="eyebrow">About</p>
      <h1>A China travel publication built for the moment a trip starts becoming real.</h1>
      <p>
        China Travel Notes is for travelers figuring out route shape, city fit, hotel areas, transport logic, and the
        practical basics that make the first few days feel much easier.
      </p>
    </article>

    <aside class="card-surface stack">
      <div>
        <p class="eyebrow">Best For</p>
        <h3>Best when you want the trip to feel edited before it feels expensive.</h3>
      </div>
      <ul class="mini-list">
        <li>First-time visitors comparing cities and routes.</li>
        <li>Travelers who want the basics in plain English.</li>
        <li>Readers who want destination pieces with some judgment, not just lists.</li>
      </ul>
    </aside>
  </section>

  <section class="section-block">
    <h2 class="section-title">What The Site Tries To Do Well</h2>
    <div class="feature-grid">
      {promises.map((item) => (
        <article class="card-surface">
          <p>{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">How To Use It</h2>
    <div class="feature-grid">
      <article class="card-surface">
        <p class="eyebrow">Step 1</p>
        <h3>Start with destination hubs</h3>
        <p>Use city pages to judge pace, trip length, and whether a place belongs at the center of the route or off to the side.</p>
      </article>
      <article class="card-surface">
        <p class="eyebrow">Step 2</p>
        <h3>Move into trip topics</h3>
        <p>Sort payments, internet, airport arrival, train booking, and neighborhood questions before locking anything expensive in.</p>
      </article>
      <article class="card-surface">
        <p class="eyebrow">Step 3</p>
        <h3>Use guides for the final shape</h3>
        <p>Open itinerary and where-to-stay guides once the route already feels broadly right.</p>
      </article>
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">How The Editorial Team Works</h2>
    <div class="feature-grid">
      {deskTypes.map((item) => (
        <article class="card-surface">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
    <div class="button-row">
      <a class="button-link secondary" href="/masthead/">View masthead</a>
      <a class="button-link secondary" href="/authors/">Browse editors and desks</a>
    </div>
  </section>

  <section class="section-block card-surface">
    <p class="eyebrow">Scope</p>
    <h2 class="section-title">What This Site Is Not</h2>
    <ul class="mini-list">
      {nonPromises.map((item) => <li>{item}</li>)}
    </ul>
  </section>
</BaseLayout>
