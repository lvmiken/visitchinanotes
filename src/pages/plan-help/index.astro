---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PlanningHelpCallout from "../../components/PlanningHelpCallout.astro";
import PlanningRequestForm from "../../components/PlanningRequestForm.astro";
import { defaultContactEmail } from "../../lib/site";

const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL || defaultContactEmail;

const helpAreas = [
  {
    title: "Route and pacing check",
    description: "Best when the trip still feels too dense, too vague, or too hard to judge city by city.",
  },
  {
    title: "Hotel area and transport fit",
    description: "Best when the right city is chosen but the day-to-day movement still feels uncertain.",
  },
  {
    title: "Partner handoff for booking support",
    description: "Best when a traveler wants a human partner to help with the practical next steps.",
  },
];

const beforeYouAsk = [
  "Which cities are already fixed and which are still flexible.",
  "How many days the trip has in total.",
  "Whether the trip is more about history, food, scenery, or a smoother first experience.",
  "Any concerns about transfers, hotel changes, or arrival-day stress.",
];

const partnerSteps = [
  {
    title: "Start with the route question",
    description: "A strong request explains what feels uncertain, such as pacing, city order, or hotel-area choice.",
  },
  {
    title: "Review whether partner help is the right next step",
    description: "Some requests only need clearer guidance. Others are ready for a human booking or itinerary partner.",
  },
  {
    title: "Share only the details needed for follow-up",
    description: "If a partner introduction makes sense, the route outline and contact details can be passed along for reply.",
  },
];
---

<BaseLayout
  title="Plan Help | Route Checks And Travel Partner Introductions"
  description="Get a calmer route check, hotel-area advice, or a partner introduction for a first trip to China."
  noindex={true}
  showAds={false}
>
  <section class="split-hero">
    <div class="hero article">
      <p class="eyebrow">Plan Help</p>
      <h1>Get help when the route is almost there, but still needs a human sanity check.</h1>
      <p>
        This page is for travelers who already have a rough trip shape and want help with pacing, hotel areas,
        transport fit, or a partner introduction for the next step.
      </p>
      <div class="button-row">
        <a class="button-link primary" href="#request-help">Start the request</a>
        <a class="button-link secondary" href="/destinations/">See destination hubs</a>
        {contactEmail && <a class="button-link secondary" href={`mailto:${contactEmail}`}>Email instead</a>}
      </div>
    </div>

    <aside class="card-surface stack">
      <div>
        <p class="eyebrow">Best For</p>
        <h3>Use this when the trip is shaped, but not yet settled.</h3>
      </div>
      <ul class="mini-list">
        <li>You already have a shortlist of cities.</li>
        <li>You want a calmer route before booking more pieces.</li>
        <li>You want help without turning the whole trip into a custom tour from day one.</li>
      </ul>
    </aside>
  </section>

  <section class="section-block">
    <h2 class="section-title">What This Can Help With</h2>
    <div class="feature-grid">
      {helpAreas.map((area) => (
        <article class="card-surface">
          <h3>{area.title}</h3>
          <p>{area.description}</p>
        </article>
      ))}
    </div>
  </section>

  <PlanningHelpCallout
    eyebrow="Before You Ask"
    title="A better request starts with a clearer route outline."
    description="The more specific the route, pace, and pain points are, the easier it is to figure out the right next step."
    primaryLabel="Jump to request"
    primaryHref="#request-help"
    secondaryLabel="Read trip basics"
    secondaryHref="/topics/"
    bullets={beforeYouAsk}
  />

  <section class="section-block">
    <h2 class="section-title">How Partner Introductions Work</h2>
    <div class="feature-grid">
      {partnerSteps.map((step) => (
        <article class="card-surface">
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block card-surface">
    <p class="eyebrow">Before You Submit</p>
    <h2 class="section-title">Privacy And Partner Disclosure</h2>
    <p>
      If you ask for partner help, the trip outline and contact details may be shared with a suitable travel partner so
      they can reply directly.
    </p>
    <div class="button-row">
      <a class="button-link secondary" href="/privacy/">Read privacy details</a>
      <a class="button-link secondary" href="/editorial-policy/">Read editorial policy</a>
    </div>
  </section>

  <PlanningRequestForm />
</BaseLayout>
