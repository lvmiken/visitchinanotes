---
import { defaultContactEmail } from "../lib/site";

const formEndpoint = import.meta.env.PUBLIC_PLANNING_FORM_ENDPOINT;
const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL || defaultContactEmail;
const isLiveMode = Boolean(formEndpoint);
const canSubmit = isLiveMode || Boolean(contactEmail);
const sourcePage = Astro.url.pathname;
---

<section class="card-surface request-form-shell" id="request-help">
  <p class="eyebrow">Planning Help Request</p>
  <h2 class="section-title">Share the route outline and the kind of help you want.</h2>
  <p class="muted">
    Use this request format to summarize the route, the cities, and the kind of planning help that would make the trip easier.
  </p>
  <p class="form-mode-note">
    {isLiveMode
      ? "Live follow-up is enabled. A submitted request can be reviewed and passed to a suitable travel partner."
      : contactEmail
        ? `Requests are currently handled by email. Use the form below to prepare a pre-filled message, or write directly to ${contactEmail}.`
        : "Planning requests are not being collected on this page right now. Use the contact or masthead pages if you need to reach the editorial team."}
  </p>

  {canSubmit ? (
    <form
      class="request-form"
      action={formEndpoint || "#"}
      method="POST"
      data-request-form
      data-live-mode={isLiveMode ? "true" : "false"}
      data-contact-email={contactEmail || ""}
    >
      <input type="hidden" name="source_page" value={sourcePage} />
      <input type="hidden" name="request_origin" value="china-travel-notes" />

      <label class="honeypot-field" aria-hidden="true">
        Company website
        <input name="company_website" type="text" tabindex="-1" autocomplete="off" />
      </label>

      <label>
        Your trip outline
        <textarea
          name="trip_outline"
          rows="4"
          required
          placeholder="Example: 8 days, Shanghai + Hangzhou, first time in China, want easier hotel and transport choices."
        ></textarea>
      </label>

      <div class="grid two">
        <label>
          Trip length
          <input name="trip_length" type="text" required placeholder="Example: 7 to 10 days" />
        </label>

        <label>
          Main cities
          <input name="cities" type="text" required placeholder="Example: Beijing, Xi'an, Shanghai" />
        </label>
      </div>

      <div class="grid two">
        <label>
          What kind of help do you need?
          <select name="help_type">
            <option>Route check and pacing</option>
            <option>Hotel area and transport advice</option>
            <option>Booking support and local partner intro</option>
          </select>
        </label>

        <label>
          Contact email
          <input name="email" type="email" required placeholder="you@example.com" />
        </label>
      </div>

      <label>
        Anything the partner should know first?
        <textarea name="notes" rows="3" placeholder="Example: family trip, older parents, scenic focus, avoid too many hotel changes."></textarea>
      </label>

      <label class="consent-row">
        <input name="consent" type="checkbox" required />
        <span>I understand this request may be reviewed first and may be shared with a suitable travel partner for follow-up.</span>
      </label>

      <div class="button-row">
        <button class="button-link primary request-submit" type="submit" data-submit-button>
          {isLiveMode ? "Request Partner Help" : "Open Email Draft"}
        </button>
        {contactEmail && <a class="button-link secondary" href={`mailto:${contactEmail}`}>Plain Email</a>}
      </div>

      <p class="request-status request-success" data-request-success hidden>
        Thanks. Your request has been received and can be reviewed for the next suitable follow-up step.
      </p>

      <p class="request-status request-success" data-request-email-success hidden>
        Your email app should open with a pre-filled request draft. Send that email to complete the request.
      </p>

      <p class="request-status request-error" data-request-error hidden>
        The request could not be sent right now. Please try again in a moment.
      </p>
    </form>
  ) : (
    <div class="request-form unavailable-panel">
      <p>
        Direct request submission is not enabled on this page right now. Use the links below if you need to find the
        right editor, contact page, or policy reference first.
      </p>
      <div class="button-row">
        <a class="button-link primary" href="/contact/">Go to Contact</a>
        <a class="button-link secondary" href="/masthead/">View Masthead</a>
        <a class="button-link secondary" href="/authors/">Browse Editors</a>
      </div>
    </div>
  )}
</section>

<script>
  const form = document.querySelector("[data-request-form]");
  const success = document.querySelector("[data-request-success]");
  const error = document.querySelector("[data-request-error]");
  const submitButton = document.querySelector("[data-submit-button]");
  const emailSuccess = document.querySelector("[data-request-email-success]");

  if (
    form instanceof HTMLFormElement &&
    success instanceof HTMLElement &&
    error instanceof HTMLElement &&
    submitButton instanceof HTMLButtonElement &&
    emailSuccess instanceof HTMLElement
  ) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      success.hidden = true;
      error.hidden = true;
      emailSuccess.hidden = true;

      if (!form.reportValidity()) {
        return;
      }

      const isLiveMode = form.dataset.liveMode === "true";
      const contactEmail = form.dataset.contactEmail;

      submitButton.disabled = true;
      submitButton.textContent = isLiveMode ? "Sending request..." : contactEmail ? "Preparing email..." : "Unavailable";

      try {
        if (isLiveMode && form.action && form.action !== "#") {
          const response = await fetch(form.action, {
            method: "POST",
            body: new FormData(form),
            headers: {
              Accept: "application/json",
            },
          });

          if (!response.ok) {
            throw new Error("Request failed");
          }
        } else if (contactEmail) {
          const tripOutline = form.elements.namedItem("trip_outline");
          const tripLength = form.elements.namedItem("trip_length");
          const cities = form.elements.namedItem("cities");
          const helpType = form.elements.namedItem("help_type");
          const email = form.elements.namedItem("email");
          const notes = form.elements.namedItem("notes");
          const sourcePage = form.elements.namedItem("source_page");

          const subject = encodeURIComponent("Planning help request from China Travel Notes");
          const body = encodeURIComponent(
            [
              "New planning help request",
              "",
              `Trip outline: ${tripOutline instanceof HTMLTextAreaElement ? tripOutline.value : ""}`,
              `Trip length: ${tripLength instanceof HTMLInputElement ? tripLength.value : ""}`,
              `Main cities: ${cities instanceof HTMLInputElement ? cities.value : ""}`,
              `Help type: ${helpType instanceof HTMLSelectElement ? helpType.value : ""}`,
              `Reply email: ${email instanceof HTMLInputElement ? email.value : ""}`,
              `Notes: ${notes instanceof HTMLTextAreaElement ? notes.value : ""}`,
              `Source page: ${sourcePage instanceof HTMLInputElement ? sourcePage.value : ""}`,
            ].join("\n"),
          );

          window.location.href = `mailto:${contactEmail}?subject=${subject}&body=${body}`;
          emailSuccess.hidden = false;
          submitButton.textContent = "Open Email Draft";
          return;
        }

        success.hidden = false;
        form.reset();
      } catch (submissionError) {
        console.error(submissionError);
        error.hidden = false;
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = isLiveMode ? "Request Partner Help" : contactEmail ? "Open Email Draft" : "Request Partner Help";
      }
    });
  }
</script>

<style>
  .request-form-shell {
    background:
      linear-gradient(135deg, rgba(255, 247, 237, 0.9) 0%, rgba(255, 255, 255, 0.98) 70%),
      #ffffff;
  }

  .request-form {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }

  .form-mode-note {
    margin: 0.85rem 0 0;
    padding: 0.85rem 1rem;
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid var(--border);
    color: var(--muted);
  }

  .request-form label {
    display: grid;
    gap: 0.45rem;
    font-weight: 700;
    color: var(--text);
  }

  .request-form input,
  .request-form textarea,
  .request-form select {
    width: 100%;
    padding: 0.85rem 0.95rem;
    border: 1px solid var(--border);
    border-radius: 0.9rem;
    font: inherit;
    color: var(--text);
    background: rgba(255, 255, 255, 0.94);
  }

  .request-form textarea {
    resize: vertical;
  }

  .request-submit {
    appearance: none;
    cursor: pointer;
  }

  .consent-row {
    grid-template-columns: auto 1fr;
    align-items: start;
    font-weight: 400;
  }

  .consent-row input {
    width: auto;
    margin-top: 0.2rem;
  }

  .honeypot-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .request-status {
    margin: 0;
  }

  .request-success {
    color: #166534;
  }

  .request-error {
    color: #b91c1c;
  }
</style>
