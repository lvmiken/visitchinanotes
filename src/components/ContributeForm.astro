---
import { defaultContactEmail } from "../lib/site";

const formEndpoint = import.meta.env.PUBLIC_CONTRIBUTION_FORM_ENDPOINT;
const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL || defaultContactEmail;
const isLiveMode = Boolean(formEndpoint);
const canSubmit = isLiveMode || Boolean(contactEmail);
const sourcePage = Astro.url.pathname;
---

<section class="card-surface request-form-shell" id="contribute-form">
  <p class="eyebrow">Contributor Pitch</p>
  <h2 class="section-title">Send a topic idea, sample work, or a draft proposal.</h2>
  <p class="muted">
    This form is for writers, local experts, or experienced travelers who want to suggest an article, a city angle,
    or a practical planning topic worth covering.
  </p>
  <p class="form-mode-note">
    {isLiveMode
      ? "Contributor submissions are enabled. Suitable pitches can be reviewed and answered by email."
      : contactEmail
        ? `Contributor pitches are currently handled by email. Use the form below to prepare a pre-filled message, or send it directly to ${contactEmail}.`
        : "Contributor inquiries are not being collected on this page right now. Use the contact or masthead pages if you need to reach the editorial team."}
  </p>

  {canSubmit ? (
    <form
      class="request-form"
      action={formEndpoint || "#"}
      method="POST"
      data-contribute-form
      data-live-mode={isLiveMode ? "true" : "false"}
      data-contact-email={contactEmail || ""}
    >
      <input type="hidden" name="source_page" value={sourcePage} />
      <input type="hidden" name="submission_type" value="contributor-pitch" />

      <label class="honeypot-field" aria-hidden="true">
        Portfolio website
        <input name="portfolio_website" type="text" tabindex="-1" autocomplete="off" />
      </label>

      <div class="grid two">
        <label>
          Your name
          <input name="name" type="text" required placeholder="Example: Alex Chen" />
        </label>

        <label>
          Contact email
          <input name="email" type="email" required placeholder="you@example.com" />
        </label>
      </div>

      <label>
        What would you like to contribute?
        <select name="pitch_type">
          <option>Article idea or outline</option>
          <option>Local knowledge or city insight</option>
          <option>Full draft for review</option>
          <option>Partnership or contributor inquiry</option>
        </select>
      </label>

      <label>
        Suggested topic or working title
        <input name="topic_title" type="text" required placeholder="Example: Best Shanghai neighborhoods for first-time visitors using rail transit" />
      </label>

      <label>
        Pitch summary
        <textarea
          name="pitch_summary"
          rows="5"
          required
          placeholder="Explain the angle, why it helps the reader, and what makes your contribution useful."
        ></textarea>
      </label>

      <div class="grid two">
        <label>
          Relevant cities or topics
          <input name="focus_area" type="text" placeholder="Example: Shanghai, Suzhou, high-speed rail, hotel location" />
        </label>

        <label>
          Writing samples or links
          <input name="samples" type="text" placeholder="Example: personal site, Google Doc, portfolio URL" />
        </label>
      </div>

      <label>
        Anything we should know about your background?
        <textarea
          name="background"
          rows="3"
          placeholder="Example: based in Guangzhou, frequent inbound-travel planner, hospitality background."
        ></textarea>
      </label>

      <label class="consent-row">
        <input name="consent" type="checkbox" required />
        <span>I understand this is a submission inquiry, not a guaranteed publication commitment.</span>
      </label>

      <div class="button-row">
        <button class="button-link primary request-submit" type="submit" data-contribute-submit>
          {isLiveMode ? "Send Contribution Pitch" : "Open Email Draft"}
        </button>
        {contactEmail && <a class="button-link secondary" href={`mailto:${contactEmail}`}>Plain Email</a>}
      </div>

      <p class="request-status request-success" data-contribute-success hidden>
        Thanks. Your contribution pitch has been received and can be reviewed for follow-up.
      </p>

      <p class="request-status request-success" data-contribute-email-success hidden>
        Your email app should open with a pre-filled contributor pitch draft. Send that email to complete the submission.
      </p>

      <p class="request-status request-error" data-contribute-error hidden>
        The pitch could not be sent right now. Please try again or use email instead.
      </p>
    </form>
  ) : (
    <div class="request-form unavailable-panel">
      <p>
        Direct contributor submission is not enabled on this page right now. Use the links below if you want to review
        the team first or reach out through the main contact page.
      </p>
      <div class="button-row">
        <a class="button-link primary" href="/contact/">Go to Contact</a>
        <a class="button-link secondary" href="/masthead/">View Masthead</a>
        <a class="button-link secondary" href="/authors/">Browse Editors</a>
      </div>
    </div>
  )}
</section>

<script>
  const form = document.querySelector("[data-contribute-form]");
  const success = document.querySelector("[data-contribute-success]");
  const error = document.querySelector("[data-contribute-error]");
  const submitButton = document.querySelector("[data-contribute-submit]");
  const emailSuccess = document.querySelector("[data-contribute-email-success]");

  if (
    form instanceof HTMLFormElement &&
    success instanceof HTMLElement &&
    error instanceof HTMLElement &&
    submitButton instanceof HTMLButtonElement &&
    emailSuccess instanceof HTMLElement
  ) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      success.hidden = true;
      error.hidden = true;
      emailSuccess.hidden = true;

      if (!form.reportValidity()) {
        return;
      }

      const isLiveMode = form.dataset.liveMode === "true";
      const contactEmail = form.dataset.contactEmail;

      submitButton.disabled = true;
      submitButton.textContent = isLiveMode ? "Sending pitch..." : contactEmail ? "Preparing email..." : "Unavailable";

      try {
        if (isLiveMode && form.action && form.action !== "#") {
          const response = await fetch(form.action, {
            method: "POST",
            body: new FormData(form),
            headers: {
              Accept: "application/json",
            },
          });

          if (!response.ok) {
            throw new Error("Request failed");
          }
        } else if (contactEmail) {
          const name = form.elements.namedItem("name");
          const email = form.elements.namedItem("email");
          const pitchType = form.elements.namedItem("pitch_type");
          const topicTitle = form.elements.namedItem("topic_title");
          const pitchSummary = form.elements.namedItem("pitch_summary");
          const focusArea = form.elements.namedItem("focus_area");
          const samples = form.elements.namedItem("samples");
          const background = form.elements.namedItem("background");
          const sourcePage = form.elements.namedItem("source_page");

          const subject = encodeURIComponent("Contributor pitch from China Travel Notes");
          const body = encodeURIComponent(
            [
              "New contributor pitch",
              "",
              `Name: ${name instanceof HTMLInputElement ? name.value : ""}`,
              `Reply email: ${email instanceof HTMLInputElement ? email.value : ""}`,
              `Pitch type: ${pitchType instanceof HTMLSelectElement ? pitchType.value : ""}`,
              `Suggested topic: ${topicTitle instanceof HTMLInputElement ? topicTitle.value : ""}`,
              `Pitch summary: ${pitchSummary instanceof HTMLTextAreaElement ? pitchSummary.value : ""}`,
              `Relevant cities or topics: ${focusArea instanceof HTMLInputElement ? focusArea.value : ""}`,
              `Samples or links: ${samples instanceof HTMLInputElement ? samples.value : ""}`,
              `Background: ${background instanceof HTMLTextAreaElement ? background.value : ""}`,
              `Source page: ${sourcePage instanceof HTMLInputElement ? sourcePage.value : ""}`,
            ].join("\n"),
          );

          window.location.href = `mailto:${contactEmail}?subject=${subject}&body=${body}`;
          emailSuccess.hidden = false;
          submitButton.textContent = "Open Email Draft";
          return;
        }

        success.hidden = false;
        form.reset();
      } catch (submissionError) {
        console.error(submissionError);
        error.hidden = false;
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = isLiveMode ? "Send Contribution Pitch" : contactEmail ? "Open Email Draft" : "Send Contribution Pitch";
      }
    });
  }
</script>

<style>
  .request-form-shell {
    background:
      linear-gradient(135deg, rgba(255, 247, 237, 0.9) 0%, rgba(255, 255, 255, 0.98) 70%),
      #ffffff;
  }

  .request-form {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }

  .form-mode-note {
    margin: 0.85rem 0 0;
    padding: 0.85rem 1rem;
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid var(--border);
    color: var(--muted);
  }

  .request-form label {
    display: grid;
    gap: 0.45rem;
    font-weight: 700;
    color: var(--text);
  }

  .request-form input,
  .request-form textarea,
  .request-form select {
    width: 100%;
    padding: 0.85rem 0.95rem;
    border: 1px solid var(--border);
    border-radius: 0.9rem;
    font: inherit;
    color: var(--text);
    background: rgba(255, 255, 255, 0.94);
  }

  .request-form textarea {
    resize: vertical;
  }

  .request-submit {
    appearance: none;
    cursor: pointer;
  }

  .consent-row {
    grid-template-columns: auto 1fr;
    align-items: start;
    font-weight: 400;
  }

  .consent-row input {
    width: auto;
    margin-top: 0.2rem;
  }

  .honeypot-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .request-status {
    margin: 0;
  }

  .request-success {
    color: #166534;
  }

  .request-error {
    color: #b91c1c;
  }
</style>
