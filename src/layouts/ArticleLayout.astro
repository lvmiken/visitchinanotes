---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import CityCard from "../components/CityCard.astro";
import GuideCard from "../components/GuideCard.astro";
import TopicCard from "../components/TopicCard.astro";
import TopicClusterCard from "../components/TopicClusterCard.astro";
import PlanningHelpCallout from "../components/PlanningHelpCallout.astro";
import HeroImage from "../components/HeroImage.astro";
import { guideStageMap } from "../lib/guideStages";
import { topicMomentMap } from "../lib/topicMoments";
import { findCityEntry, getCitySlug, uniqueCityEntries } from "../lib/cityEntries";
import { getTopicClusterForTopicSlug, getTopicsForCluster } from "../lib/topicClusters";
import { getAuthorSlug, resolveAuthorEntry } from "../lib/authors";
import { organizationName } from "../lib/site";
import { getGuideSocialImage, getTopicSocialImage } from "../lib/socialImages";

interface Props {
  entry: CollectionEntry<"guides"> | CollectionEntry<"topics">;
  breadcrumbs: { label: string; href?: string }[];
}

const { entry, breadcrumbs } = Astro.props;
const isGuide = entry.collection === "guides";
const allCities = await getCollection("cities");
const allAuthors = await getCollection("authors");
const allTopics = await getCollection("topics", ({ data }) => !data.draft);
const allGuides = await getCollection("guides", ({ data }) => !data.draft);
const cityHub = isGuide ? findCityEntry(allCities, entry.data.city) : undefined;
const authorEntry =
  entry.collection === "places"
    ? undefined
    : resolveAuthorEntry(allAuthors, entry);
const bylineLabel = authorEntry?.data.entityType === "organization" ? "Edited by" : "By";
const relatedTopics = isGuide
  ? [
      ...entry.data.relatedTopicSlugs
        .map((slug) => allTopics.find((topic) => topic.slug === slug))
        .filter(Boolean),
      ...allTopics.filter((topic) => !entry.data.relatedTopicSlugs.includes(topic.slug)),
    ].slice(0, 2)
  : [
      ...allTopics.filter(
        (topic) => topic.slug !== entry.slug && topic.data.planningMoment === entry.data.planningMoment,
      ),
      ...allTopics.filter((topic) => topic.slug !== entry.slug),
    ].slice(0, 2);
const relatedGuides = isGuide
  ? allGuides
      .filter(
        (guide) =>
          guide.slug !== entry.slug &&
          guide.data.city.toLowerCase() === entry.data.city.toLowerCase(),
      )
      .slice(0, 2)
  : [
      ...entry.data.relatedGuideSlugs
        .map((slug) => allGuides.find((guide) => guide.slug === slug))
        .filter(Boolean),
      ...allGuides.filter((guide) => !entry.data.relatedGuideSlugs.includes(guide.slug)),
    ].slice(0, 2);
const stageLabel = isGuide ? guideStageMap[entry.data.guideStage]?.label : undefined;
const topicMomentLabel = !isGuide ? topicMomentMap[entry.data.planningMoment]?.label : undefined;
const guideEyebrow = isGuide ? cityHub?.data.name ?? entry.data.city : "Trip Topic";
const relatedCities = !isGuide
  ? uniqueCityEntries(entry.data.affectsCities.map((cityName) => findCityEntry(allCities, cityName))).slice(0, 4)
  : [];
const topicCluster = !isGuide ? getTopicClusterForTopicSlug(entry.slug) : undefined;
const moreInCluster =
  !isGuide && topicCluster
    ? getTopicsForCluster(topicCluster, allTopics).filter((topic) => topic.slug !== entry.slug).slice(0, 3)
    : [];
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const heroImageUrl = entry.data.heroImage ? new URL(entry.data.heroImage, siteUrl).href : undefined;
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, siteUrl).href } : { item: canonical }),
  })),
};
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.publishDate.toISOString(),
  dateModified: (entry.data.updatedDate ?? entry.data.publishDate).toISOString(),
  author: authorEntry
    ? {
        "@type": authorEntry.data.entityType === "organization" ? "Organization" : "Person",
        name: authorEntry.data.name,
        url: new URL(`/authors/${getAuthorSlug(authorEntry)}/`, siteUrl).href,
        description: authorEntry.data.shortBio,
      }
    : {
        "@type": "Person",
        name: entry.data.author,
      },
  publisher: {
    "@type": "Organization",
    name: organizationName,
  },
  mainEntityOfPage: canonical,
  ...(heroImageUrl ? { image: [heroImageUrl] } : {}),
  articleSection: isGuide ? stageLabel : topicMomentLabel,
  keywords: entry.data.tags.join(", "),
};
const faqSchema =
  entry.data.faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: entry.data.faq.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
          },
        })),
      }
    : undefined;
const pageSchemas = faqSchema ? [breadcrumbSchema, articleSchema, faqSchema] : [breadcrumbSchema, articleSchema];
const socialImage = isGuide ? getGuideSocialImage(entry) : getTopicSocialImage(entry);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  socialImage={socialImage}
  type="article"
  noindex={entry.data.noindex ?? false}
  publishedTime={entry.data.publishDate}
  modifiedTime={entry.data.updatedDate}
  schema={pageSchemas}
>
  <section class="split-hero">
    <article class="hero article">
      <div class="article-header">
        <Breadcrumbs items={breadcrumbs} />
        <p class="eyebrow">{guideEyebrow}</p>
        <h1>{entry.data.title}</h1>
        <p>{entry.data.description}</p>
        <p class="meta-row">
          {bylineLabel} {authorEntry ? <a href={`/authors/${getAuthorSlug(authorEntry)}/`}>{authorEntry.data.name}</a> : entry.data.author}
          {" · "}Published {entry.data.publishDate.toLocaleDateString("en-US")}
          {entry.data.updatedDate && ` · Updated ${entry.data.updatedDate.toLocaleDateString("en-US")}`}
        </p>
        {entry.data.tags.length > 0 && (
          <ul class="tag-list">
            {entry.data.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        )}
      </div>
    </article>

    <aside class="card-surface stack">
      <div>
        <p class="eyebrow">At A Glance</p>
        <h3>{isGuide ? "Read this once the city is in play and the details start to matter." : "Read this when one practical question begins shaping the rest of the trip."}</h3>
      </div>
      <p>{isGuide
        ? "Use it for stay decisions, trip length, city priorities, and the shape of the stop."
        : entry.data.whenToRead}</p>
      <ul class="mini-list">
        {(isGuide ? entry.data.keyTakeaways : entry.data.beforeYouBookChecklist).slice(0, 3).map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      {isGuide ? (
        <div>
          <p class="eyebrow">How To Use It</p>
          <p><strong>Planning stage:</strong> {stageLabel}</p>
          {entry.data.tripLength && <p><strong>Typical trip length:</strong> {entry.data.tripLength}</p>}
          {entry.data.whoItsFor.length > 0 && (
            <p><strong>Good match for:</strong> {entry.data.whoItsFor.join(", ")}</p>
          )}
          {cityHub && (
            <p><strong>Destination hub:</strong> <a href={`/destinations/${getCitySlug(cityHub)}/`}>{cityHub.data.name}</a></p>
          )}
        </div>
      ) : (
        <div>
          <p class="eyebrow">How To Use It</p>
          {topicMomentLabel && <p><strong>Best read when:</strong> {topicMomentLabel}</p>}
          {entry.data.affectsCities.length > 0 && (
            <p><strong>Most relevant in:</strong> {entry.data.affectsCities.join(", ")}</p>
          )}
        </div>
      )}
    </aside>
  </section>

  {entry.data.heroImage && (
    <section class="section-block">
      <HeroImage
        src={entry.data.heroImage}
        alt={entry.data.heroImageAlt ?? entry.data.title}
        attributionName={entry.data.heroImageAttributionName}
        attributionUrl={entry.data.heroImageAttributionUrl}
        license={entry.data.heroImageLicense}
      />
    </section>
  )}

  <article class="article section-block">
    {entry.data.keyTakeaways.length > 0 && (
      <section class="section-block card-surface">
        <h2 class="section-title">Key Takeaways</h2>
        <ul class="mini-list">
          {entry.data.keyTakeaways.map((takeaway) => <li>{takeaway}</li>)}
        </ul>
      </section>
    )}
    <slot />
    {!isGuide && entry.data.beforeYouBookChecklist.length > 0 && (
      <section class="section-block card-surface">
        <h2 class="section-title">Before You Book</h2>
        <ul class="mini-list">
          {entry.data.beforeYouBookChecklist.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    )}
    {entry.data.faq.length > 0 && (
      <section class="section-block">
        <h2>FAQ</h2>
        {entry.data.faq.map((item) => (
          <>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </>
        ))}
      </section>
    )}
  </article>

  <section class="section-block post-reading-tools" aria-label="Article notes and next steps">
    <div class="support-grid">
      <section class="card-surface support-card">
        <p class="eyebrow">About This Piece</p>
        <h2 class="support-title">What we checked</h2>
        <p class="muted">
          First published {entry.data.publishDate.toLocaleDateString("en-US")}
          {entry.data.updatedDate ? ` · Updated ${entry.data.updatedDate.toLocaleDateString("en-US")}` : ""}
        </p>
        <p>
          {isGuide
            ? "We revisit city guides when route logic, stay advice, or local assumptions shift enough to change the reader's decisions."
            : "We revisit practical topic pages when booking, payment, arrival, or transport details shift in ways that change the advice."}
        </p>
        <div class="button-row">
          <a class="button-link secondary" href="/editorial-policy/">How we edit</a>
          {authorEntry && (
            <a class="button-link secondary" href={`/authors/${getAuthorSlug(authorEntry)}/`}>
              {authorEntry.data.entityType === "organization" ? "Meet the desk" : "Meet the editor"}
            </a>
          )}
        </div>
      </section>

      {isGuide && cityHub && (
        <section class="card-surface support-card">
          <p class="eyebrow">Back To The City</p>
          <h2 class="support-title">Read this inside the wider {cityHub.data.name} story.</h2>
          <p class="muted">
            The destination hub gathers stays, neighborhoods, pacing, and practical city reads in one place.
          </p>
          <div class="button-row">
            <a class="button-link primary" href={`/destinations/${getCitySlug(cityHub)}/`}>Open {cityHub.data.name} hub</a>
            <a class="button-link secondary" href="/destinations/">Browse destinations</a>
          </div>
        </section>
      )}

      {!isGuide && topicCluster && (
        <section class="card-surface support-card">
          <p class="eyebrow">In This Topic Series</p>
          <h2 class="support-title">See where this question sits in the wider planning thread.</h2>
          <p class="muted">{topicCluster.description}</p>
          <div class="button-row">
            <a class="button-link primary" href={`/topics/${topicCluster.slug}/`}>Open {topicCluster.title}</a>
            <a class="button-link secondary" href="/topics/">Browse topics</a>
          </div>
        </section>
      )}
    </div>
  </section>

  {!isGuide && relatedCities.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Destination Hubs Connected To This Topic</h2>
      <div class="grid two">
        {relatedCities.map((city) => <CityCard city={city} />)}
      </div>
    </section>
  )}

  {!isGuide && topicCluster && (
    <section class="section-block">
      <h2 class="section-title">Topic Hub</h2>
      <div class="grid two">
        <TopicClusterCard cluster={topicCluster} />
      </div>
    </section>
  )}

  {!isGuide && moreInCluster.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">More In This Topic Hub</h2>
      <div class="grid two">
        {moreInCluster.map((topic) => <TopicCard topic={topic} />)}
      </div>
    </section>
  )}

  <PlanningHelpCallout
    title={isGuide ? `${entry.data.city} still needs a clearer shape?` : "Still deciding this part of the trip?"}
    description={isGuide
      ? "If this guide clarified the city but not yet the pacing, hotel area, or what comes next, it may be time for a second pair of eyes."
      : "If this page added context but the real decision still feels unsettled, a short planning note can help turn it into next steps."}
    primaryLabel="Talk through the route"
    primaryHref="/plan-help/"
    secondaryLabel={isGuide ? "Browse destination hubs" : "Browse topic hubs"}
    secondaryHref={isGuide ? "/destinations/" : "/topics/"}
    bullets={isGuide
      ? [
          "Sense-check how much time the city really needs.",
          "Work out hotel area and transfer logic before bookings harden.",
          "Ask for human help only where the route is still sticky.",
        ]
      : [
          "Useful when one practical question is still holding up the whole plan.",
          "Good for turning general advice into city-specific next steps.",
          "Best kept narrow: one question, one route, one decision.",
        ]}
  />

  {authorEntry && (
    <section class="section-block card-surface">
      <p class="eyebrow">{authorEntry.data.entityType === "organization" ? "About The Desk" : "About The Author"}</p>
      <h2 class="section-title">{authorEntry.data.name}</h2>
      <p><strong>{authorEntry.data.role}</strong></p>
      <p>{authorEntry.data.fullBio}</p>
      {authorEntry.data.expertise.length > 0 && (
        <ul class="tag-list">
          {authorEntry.data.expertise.map((item) => <li>{item}</li>)}
        </ul>
      )}
      <div class="button-row">
        <a class="button-link primary" href={`/authors/${getAuthorSlug(authorEntry)}/`}>
          {authorEntry.data.entityType === "organization" ? "Meet the desk" : "Meet the editor"}
        </a>
        <a class="button-link secondary" href="/authors/">All editors and desks</a>
      </div>
    </section>
  )}

  {isGuide && relatedGuides.length > 0 && cityHub && (
    <section class="section-block">
      <h2 class="section-title">More For {cityHub.data.name}</h2>
      <div class="grid two">
        {relatedGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </section>
  )}

  {!isGuide && relatedGuides.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Guides To Read Alongside This</h2>
      <div class="grid two">
        {relatedGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </section>
  )}

  {relatedTopics.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Read Next</h2>
      <div class="grid two">
        {relatedTopics.map((topic) => <TopicCard topic={topic} />)}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .post-reading-tools {
    margin-top: 2rem;
  }

  .support-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    align-items: start;
  }

  .support-card {
    padding: 1rem 1.1rem;
  }

  .support-title {
    margin: 0 0 0.5rem;
    font-size: 1.15rem;
    line-height: 1.3;
  }

  .support-card p {
    margin: 0.45rem 0;
  }

  .support-card .button-row {
    margin-top: 0.9rem;
  }

  .support-card .button-link {
    padding: 0.68rem 0.95rem;
  }
</style>
