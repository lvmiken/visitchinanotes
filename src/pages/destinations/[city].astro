---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import GuideCard from "../../components/GuideCard.astro";
import TopicCard from "../../components/TopicCard.astro";
import CityCard from "../../components/CityCard.astro";
import PlaceCard from "../../components/PlaceCard.astro";
import PlanningHelpCallout from "../../components/PlanningHelpCallout.astro";
import HeroImage from "../../components/HeroImage.astro";
import { guideStages } from "../../lib/guideStages";
import { findCityEntry, getCitySlug, uniqueCityEntries } from "../../lib/cityEntries";
import { getCitySocialImage } from "../../lib/socialImages";

const broadTopicFallbacks = {
  "choose-route": ["plan-your-trip", "where-to-start"],
  "solve-basics": [],
  "book-transport": ["high-speed-rail", "train-vs-flight", "airport-to-city"],
};

function formatList(items) {
  if (items.length === 0) {
    return "";
  }

  if (items.length === 1) {
    return items[0];
  }

  if (items.length === 2) {
    return `${items[0]} and ${items[1]}`;
  }

  return `${items.slice(0, -1).join(", ")}, and ${items.at(-1)}`;
}

export async function getStaticPaths() {
  const cities = await getCollection("cities");

  return cities.map((city) => ({
    params: { city: getCitySlug(city) },
    props: { city },
  }));
}

const { city } = Astro.props;
const allCities = await getCollection("cities");

const allGuides = (await getCollection("guides", ({ data }) => !data.draft)).filter(
  (guide) => guide.data.city.toLowerCase() === getCitySlug(city).toLowerCase(),
);
const allPlaces = (await getCollection("places", ({ data }) => !data.draft)).filter(
  (place) => place.data.city.toLowerCase() === getCitySlug(city).toLowerCase(),
);

const relatedGuides = [
  ...city.data.featuredGuideSlugs
    .map((slug) => allGuides.find((guide) => guide.slug === slug))
    .filter(Boolean),
  ...allGuides.filter((guide) => !city.data.featuredGuideSlugs.includes(guide.slug)),
];
const relatedPlaces = [
  ...city.data.featuredPlaceSlugs
    .map((slug) => allPlaces.find((place) => place.slug === slug))
    .filter(Boolean),
  ...allPlaces.filter((place) => !city.data.featuredPlaceSlugs.includes(place.slug)),
].slice(0, 10);
const featuredPlaceQuickLinks = relatedPlaces.slice(0, 4);

const allTopics = await getCollection("topics", ({ data }) => !data.draft);
const citySlug = getCitySlug(city);
const featuredTopicOrder = new Map(city.data.featuredTopicSlugs.map((slug, index) => [slug, index]));
const topicSignals = allTopics
  .map((topic) => {
    let score = 0;
    const isFeaturedTopic = city.data.featuredTopicSlugs.includes(topic.slug);
    const matchesFeaturedCity = topic.data.featuredCitySlugs.includes(citySlug);
    const matchesAffectedCity = topic.data.affectsCities.includes(city.data.name);
    const hasDirectCityMatch = matchesFeaturedCity || matchesAffectedCity;
    const hasAnyCityMatch = isFeaturedTopic || hasDirectCityMatch;

    if (!hasAnyCityMatch) {
      return null;
    }

    if (isFeaturedTopic) {
      score += 100;
    }

    if (matchesFeaturedCity) {
      score += 70;
    }

    if (matchesAffectedCity) {
      score += 40;
    }

    if (hasDirectCityMatch && topic.data.planningMoment === "solve-basics") {
      score += 8;
    }

    if (hasDirectCityMatch && topic.data.planningMoment === "book-transport") {
      score += 6;
    }

    return {
      topic,
      score,
      isFeaturedTopic,
      hasDirectCityMatch,
    };
  })
  .filter(Boolean);

function compareTopicSignals(a, b) {
  if (b.score !== a.score) {
    return b.score - a.score;
  }

  const featuredOrderA = featuredTopicOrder.get(a.topic.slug) ?? Number.POSITIVE_INFINITY;
  const featuredOrderB = featuredTopicOrder.get(b.topic.slug) ?? Number.POSITIVE_INFINITY;

  if (featuredOrderA !== featuredOrderB) {
    return featuredOrderA - featuredOrderB;
  }

  const dateA = a.topic.data.updatedDate ?? a.topic.data.publishDate;
  const dateB = b.topic.data.updatedDate ?? b.topic.data.publishDate;

  return dateB.valueOf() - dateA.valueOf();
}

function pickTopicsForMoment(planningMoment, limit) {
  const momentSignals = topicSignals.filter((signal) => signal.topic.data.planningMoment === planningMoment);
  const directMatches = momentSignals.filter((signal) => signal.hasDirectCityMatch).sort(compareTopicSignals);
  const featuredMatches = momentSignals.filter((signal) => signal.isFeaturedTopic).sort(compareTopicSignals);
  const fallbackMatches = (broadTopicFallbacks[planningMoment] ?? [])
    .map((slug) => allTopics.find((topic) => topic.slug === slug && topic.data.planningMoment === planningMoment))
    .filter(Boolean);
  const selected = [];
  const seen = new Set();

  for (const group of [
    directMatches.map((signal) => signal.topic),
    fallbackMatches,
    featuredMatches.map((signal) => signal.topic),
  ]) {
    for (const topic of group) {
      if (seen.has(topic.slug)) {
        continue;
      }

      seen.add(topic.slug);
      selected.push(topic);

      if (selected.length >= limit) {
        return selected;
      }
    }
  }

  return selected;
}

const chooseRouteTopics = pickTopicsForMoment("choose-route", 2);
const arrivalTopics = pickTopicsForMoment("solve-basics", 2);
const transportTopics = pickTopicsForMoment("book-transport", 2);

const topicMomentsForCity = [
  {
    title: `Before You Finalize ${city.data.name}`,
    description: "Read these first if you are still deciding whether this city fits the route and how it should be used.",
    topics: chooseRouteTopics,
  },
  {
    title: "Before Arrival",
    description: "These topics reduce day-one friction around entry, internet, payment, and getting into the city smoothly.",
    topics: arrivalTopics,
  },
  {
    title: "Before You Book Transport",
    description: "Use these when rail, flights, airport transfers, or intercity timing start to shape the route.",
    topics: transportTopics,
  },
].filter((group) => group.topics.length > 0);

const guidesByStage = guideStages
  .map((stage) => ({
    ...stage,
    guides: relatedGuides.filter((guide) => guide.data.guideStage === stage.id),
  }))
  .filter((group) => group.guides.length > 0);
const quickStartGuides = relatedGuides.slice(0, 6);
const practicalGuides = relatedGuides
  .map((guide) => {
    let score = 0;
    const slug = guide.slug;

    if (slug.includes("where-to-stay")) score += 100;
    if (slug.includes("airport-to-city")) score += 90;
    if (slug.includes("how-to-get-around")) score += 80;
    if (slug.includes("what-to-book-in-advance")) score += 70;
    if (slug.includes("rainy-day")) score += 60;
    if (guide.data.guideStage === "plan-stay") score += 30;
    if (guide.data.guideStage === "solve-logistics") score += 25;

    return { guide, score };
  })
  .filter(({ score }) => score > 0)
  .sort((a, b) => {
    if (b.score !== a.score) {
      return b.score - a.score;
    }

    const aDate = a.guide.data.updatedDate ?? a.guide.data.publishDate;
    const bDate = b.guide.data.updatedDate ?? b.guide.data.publishDate;

    return bDate.valueOf() - aDate.valueOf();
  })
  .map(({ guide }) => guide)
  .slice(0, 4);
const choiceGuide =
  relatedGuides.find((guide) => guide.data.guideStage === "choose-destination") ?? relatedGuides[0];
const stayGuide =
  practicalGuides.find((guide) => guide.slug.includes("where-to-stay")) ??
  relatedGuides.find((guide) => guide.data.guideStage === "plan-stay");
const logisticsGuide =
  practicalGuides.find((guide) =>
    ["airport-to-city", "how-to-get-around", "what-to-book-in-advance"].some((token) =>
      guide.slug.includes(token),
    ),
  ) ??
  relatedGuides.find((guide) => guide.data.guideStage === "solve-logistics");
const routeTopic = chooseRouteTopics[0];
const basicsTopic = arrivalTopics[0];
const primaryPlace = relatedPlaces[0];
const secondaryPlace = relatedPlaces[1];
const tripPaceNarrative = city.data.tripPace.endsWith(".")
  ? city.data.tripPace
  : `${city.data.tripPace}.`;

const clusterSteps = [
  {
    title: `Decide whether ${city.data.name} fits the trip`,
    description: `Start with pages that help you judge pace, trip length, and whether ${city.data.name} should be a main stop or an add-on.`,
      links: [
        ...relatedGuides
          .filter((guide) => guide.data.guideStage === "choose-destination")
          .map((guide) => ({
            href: `/guides/${guide.slug}/`,
            label: guide.data.title,
            kind: "Guide",
          })),
        ...chooseRouteTopics.map((topic) => ({
          href: `/topics/${topic.slug}/`,
          label: topic.data.title,
          kind: "Topic",
        })),
    ].slice(0, 3),
  },
  {
    title: `Shape the stay in ${city.data.name}`,
    description: "Move next into hotel area, trip length, and the city rhythm that will make the stop feel manageable.",
    links: [
      ...relatedGuides
        .filter((guide) => guide.data.guideStage === "plan-stay")
        .map((guide) => ({
          href: `/guides/${guide.slug}/`,
          label: guide.data.title,
          kind: "Guide",
        })),
      ...relatedGuides
        .filter((guide) => guide.data.guideStage === "build-itinerary")
        .map((guide) => ({
          href: `/guides/${guide.slug}/`,
          label: guide.data.title,
          kind: "Guide",
        })),
    ].slice(0, 3),
  },
  ...(relatedPlaces.length > 0
    ? [
        {
          title: `Choose the places that deserve planning in ${city.data.name}`,
          description: "Use place pages when one museum, neighborhood, park, or landmark starts deciding the shape of the day.",
          links: relatedPlaces.slice(0, 3).map((place) => ({
            href: `/places/${place.slug}/`,
            label: place.data.title,
            kind: "Place",
          })),
        },
      ]
    : []),
  {
    title: "Lock in practical details",
    description: "Use supporting topic pages once payments, rail timing, and booking assumptions start to shape what is realistic.",
    links: [...arrivalTopics, ...transportTopics]
      .map((topic) => ({
        href: `/topics/${topic.slug}/`,
        label: topic.data.title,
        kind: "Topic",
      }))
      .slice(0, 3),
  },
].filter((step) => step.links.length > 0);

const pairingCities = uniqueCityEntries(
  city.data.pairWith.map((pairing) => findCityEntry(allCities, pairing)),
);
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const heroImageUrl = city.data.heroImage ? new URL(city.data.heroImage, siteUrl).href : undefined;
const pageSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: new URL("/", siteUrl).href,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Destinations",
        item: new URL("/destinations/", siteUrl).href,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: city.data.name,
        item: canonical,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "TravelDestination",
    name: city.data.name,
    description: city.data.seoDescription,
    url: canonical,
    ...(heroImageUrl ? { image: heroImageUrl } : {}),
    touristType: city.data.idealFor,
  },
];
const socialImage = getCitySocialImage(city);
---

<BaseLayout
  title={city.data.seoTitle}
  description={city.data.seoDescription}
  socialImage={socialImage}
  schema={pageSchemas}
>
  <section class="split-hero">
    <div class="hero article">
      <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Destinations", href: "/destinations/" }, { label: city.data.name }]} />
      <p class="eyebrow">Destination Hub</p>
      <h1>{city.data.name}</h1>
      <p>{city.data.intro}</p>
      <div class="button-row">
        <a class="button-link primary" href="#city-guides">Start with {city.data.name} reads</a>
        <a class="button-link secondary" href="#trip-basics">See trip basics</a>
        {relatedPlaces.length > 0 && <a class="button-link secondary" href="#places-cluster">See place picks</a>}
      </div>
    </div>

    <aside class="card-surface stack">
      <div>
        <p class="eyebrow">Trip Snapshot</p>
        <h3>Why this city works</h3>
      </div>
      <p><strong>Ideal for:</strong> {city.data.idealFor.join(", ")}</p>
      <p><strong>Suggested stay:</strong> {city.data.suggestedStay}</p>
      <p><strong>Pace:</strong> {city.data.tripPace}</p>
      <p><strong>Pairs well with:</strong> {city.data.pairWith.join(", ")}</p>
      <p class="muted">Best months: {city.data.bestMonths.join(", ")}</p>
    </aside>
  </section>

  {city.data.heroImage && (
    <section class="section-block">
      <HeroImage
        src={city.data.heroImage}
        alt={city.data.heroImageAlt ?? `${city.data.name} skyline or landmark view`}
        attributionName={city.data.heroImageAttributionName}
        attributionUrl={city.data.heroImageAttributionUrl}
        license={city.data.heroImageLicense}
      />
    </section>
  )}

  <section class="section-block">
    <h2 class="section-title">How {city.data.name} Fits A First Trip</h2>
    <div class="card-surface narrative-block">
      <p>
        {city.data.name} is usually strongest for travelers who want{" "}
        <strong>{formatList(city.data.idealFor)}</strong>. Most first-time visits work best when the city is given{" "}
        <strong>{city.data.suggestedStay}</strong>, because that is normally enough space to protect the main payoff
        without making the route feel padded.
      </p>
      <p>
        {tripPaceNarrative} For many readers,
        the real planning question is not just whether to go, but what role the stop should play in the wider route.
        If you are still deciding that part, start with{" "}
        {choiceGuide ? <a href={`/guides/${choiceGuide.slug}/`}>{choiceGuide.data.title}</a> : city.data.seoTitle}
        {routeTopic && (
          <>
            {" "}and{" "}
            <a href={`/topics/${routeTopic.slug}/`}>{routeTopic.data.title}</a>
          </>
        )}
        .
      </p>
      <p>
        {city.data.name} also becomes easier once you decide early whether it should pair with{" "}
        <strong>{formatList(city.data.pairWith)}</strong> or carry more weight on its own. That is usually the point
        where hotel area, transfer timing, and one or two anchor places start mattering more than the raw attraction
        count.
        {stayGuide && (
          <>
            {" "}A good next move is{" "}
            <a href={`/guides/${stayGuide.slug}/`}>{stayGuide.data.title}</a>
          </>
        )}
        {logisticsGuide && (
          <>
            {" "}plus{" "}
            <a href={`/guides/${logisticsGuide.slug}/`}>{logisticsGuide.data.title}</a>
          </>
        )}
        {basicsTopic && (
          <>
            {" "}so the practical side stays realistic alongside{" "}
            <a href={`/topics/${basicsTopic.slug}/`}>{basicsTopic.data.title}</a>
          </>
        )}
        .
      </p>
      {(primaryPlace || secondaryPlace) && (
        <p>
          Once one specific sight or district starts shaping the day, move from general planning into place pages.
          {primaryPlace && (
            <>
              {" "}Most first-time visitors begin with{" "}
              <a href={`/places/${primaryPlace.slug}/`}>{primaryPlace.data.title}</a>
            </>
          )}
          {secondaryPlace && (
            <>
              {" "}and{" "}
              <a href={`/places/${secondaryPlace.slug}/`}>{secondaryPlace.data.title}</a>
            </>
          )}
          {" "}before they lock the day order.
        </p>
      )}
      {city.data.planningPriorities.length > 0 && (
        <ul class="narrative-checklist">
          {city.data.planningPriorities.map((priority) => (
            <li>
              <strong>{priority.title}:</strong> {priority.description}
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">Start Here in {city.data.name}</h2>
    <div class="feature-grid">
      {city.data.planningPriorities.map((priority, index) => (
        <article class="card-surface">
          <p class="eyebrow">Priority {index + 1}</p>
          <h3>{priority.title}</h3>
          <p>{priority.description}</p>
        </article>
      ))}
    </div>
  </section>

  {quickStartGuides.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Start With These Reads</h2>
      <p class="muted">
        If {city.data.name} is already on the short list, these are the clearest pieces to read first before you go
        deeper into hotels, day order, or booking details.
      </p>
      <div class="grid two">
        {quickStartGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </section>
  )}

  {practicalGuides.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Practical Reads That Carry The Trip</h2>
      <p class="muted">
        Once the city is firmly in the route, these are usually the pages that keep the trip feeling smooth: where to
        stay, how to arrive, how to move around, what to book early, and how to recover a day that shifts under you.
      </p>
      <div class="grid two">
        {practicalGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </section>
  )}

  {clusterSteps.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Build {city.data.name} In A Sensible Order</h2>
      <div class="feature-grid">
        {clusterSteps.map((step, index) => (
          <article class="card-surface">
            <p class="eyebrow">Step {index + 1}</p>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
            <ul class="hub-link-list">
              {step.links.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                  <span>{link.kind}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="section-block">
    <h2 class="section-title">Why Travelers Choose {city.data.name}</h2>
    <div class="feature-grid">
      {city.data.highlights.map((highlight) => (
        <article class="card-surface">
          <p>{highlight}</p>
        </article>
      ))}
    </div>
    <p class="muted" style="margin-top: 1rem;">{city.data.transportNote}</p>
  </section>

  <section class="section-block" id="city-guides">
    <h2 class="section-title">Planning Reads For {city.data.name}</h2>
    {guidesByStage.length > 0 ? (
      <div class="stack">
        {guidesByStage.map((group) => (
          <section class="card-surface">
            <h3>{group.label}</h3>
            <p class="muted">{group.description}</p>
            <div class="grid two">
              {group.guides.map((guide) => <GuideCard guide={guide} />)}
            </div>
          </section>
        ))}
      </div>
    ) : (
      <p>More city-specific guides are on the way. For now, start with the trip basics below before you lock in plans.</p>
    )}
  </section>

  {relatedPlaces.length > 0 && (
    <section class="section-block" id="places-cluster">
      <h2 class="section-title">Places That Shape A {city.data.name} Day</h2>
      <p class="muted">
        These place pages cover the landmarks, neighborhoods, museums, and high-traffic districts that most often end
        up deciding timing, route logic, or where the day should begin and end.
      </p>
      {featuredPlaceQuickLinks.length > 0 && (
        <p class="muted">
          Most first-time visitors start by comparing{" "}
          {featuredPlaceQuickLinks.map((place, index) => (
            <>
              {index > 0 && (index === featuredPlaceQuickLinks.length - 1 ? " and " : ", ")}
              <a href={`/places/${place.slug}/`}>{place.data.title}</a>
            </>
          ))}
          {" "}before they lock the day order.
        </p>
      )}
      <div class="button-row">
        <a class="button-link secondary" href="/places/">All place guides</a>
      </div>
      <div class="grid two">
        {relatedPlaces.map((place) => <PlaceCard place={place} />)}
      </div>
    </section>
  )}

  {pairingCities.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Good Pairings With {city.data.name}</h2>
      <p class="muted">These nearby or complementary stops can turn {city.data.name} into a more balanced wider route.</p>
      <div class="grid two">
        {pairingCities.map((pairingCity) => <CityCard city={pairingCity} />)}
      </div>
    </section>
  )}

  <section class="section-block" id="trip-basics">
    <h2 class="section-title">Trip Basics For {city.data.name}</h2>
    <p class="muted">These topic pages answer the practical questions that quietly decide whether the city feels easy, expensive, rushed, or surprisingly calm.</p>
    <div class="stack">
      {topicMomentsForCity.map((group) => (
        <section class="card-surface">
          <h3>{group.title}</h3>
          <p class="muted">{group.description}</p>
          <div class="grid two">
            {group.topics.map((topic) => <TopicCard topic={topic} />)}
          </div>
        </section>
      ))}
    </div>
  </section>

  <PlanningHelpCallout
    title={`Need help turning ${city.data.name} into a workable route?`}
    description={`If the city looks right but the stay length, hotel area, or onward pairing still feels uncertain, this is the point where a light planning check can help.`}
    primaryLabel="Ask for a route check"
    primaryHref="/plan-help/"
    secondaryLabel={`Back to ${city.data.name} reads`}
    secondaryHref="#city-guides"
    bullets={[
      `Check whether ${city.data.name} should be a main stop or an add-on.`,
      "Get a quick sense-check on hotel area, route pacing, and transfer fit.",
      "Use a partner introduction only when you want human help with the next step.",
    ]}
  />
</BaseLayout>

<style>
  .narrative-block p + p {
    margin-top: 1rem;
  }

  .narrative-checklist {
    margin: 1.25rem 0 0;
    padding-left: 1.2rem;
  }

  .narrative-checklist li + li {
    margin-top: 0.7rem;
  }

  .hub-link-list {
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .hub-link-list li + li {
    margin-top: 0.65rem;
  }

  .hub-link-list a {
    color: var(--text);
    font-weight: 700;
    text-decoration: none;
  }

  .hub-link-list a:hover {
    text-decoration: underline;
  }

  .hub-link-list span {
    display: block;
    color: var(--muted);
    font-size: 0.9rem;
  }
</style>
