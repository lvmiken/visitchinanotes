---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AuthorCard from "../../components/AuthorCard.astro";
import { getAuthorSlug, resolveAuthorEntry } from "../../lib/authors";

const authors = await getCollection("authors");
const guides = await getCollection("guides", ({ data }) => !data.draft);
const topics = await getCollection("topics", ({ data }) => !data.draft);
const places = await getCollection("places", ({ data }) => !data.draft);

const specialistDeskIds = new Set([
  "route-planning-desk",
  "travel-readiness-desk",
  "entry-and-visa-desk",
  "family-travel-desk",
  "transport-and-payments-desk",
]);

const authorSummaries = authors
  .map((author) => {
    const articleCount =
      guides.filter((guide) => resolveAuthorEntry(authors, guide)?.id === author.id).length +
      topics.filter((topic) => resolveAuthorEntry(authors, topic)?.id === author.id).length +
      places.filter((place) => resolveAuthorEntry(authors, place)?.id === author.id).length;

    return {
      author,
      articleCount,
      href: `/authors/${getAuthorSlug(author)}/`,
    };
  })
  .sort((a, b) => b.articleCount - a.articleCount);

const editors = authorSummaries.filter(({ author }) => author.data.entityType === "person");
const cityDesks = authorSummaries.filter(
  ({ author }) => author.data.entityType === "organization" && !specialistDeskIds.has(author.id) && author.id !== "editorial-team",
);
const specialistDesks = authorSummaries.filter(
  ({ author }) => author.data.entityType === "organization" && specialistDeskIds.has(author.id),
);
const totalPublishedPages = guides.length + topics.length + places.length;
---

<BaseLayout
  title="Masthead | China Travel Notes"
  description="Meet the editors and desks behind China Travel Notes and see how destination, route-planning, and trip-basics coverage is organized."
  showAds={false}
>
  <section class="split-hero">
    <article class="hero article">
      <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Masthead" }]} />
      <p class="eyebrow">Masthead</p>
      <h1>Meet the editors and desks behind the coverage.</h1>
      <p>
        China Travel Notes is built around named editors and specialist desks, so destination pieces, cross-country
        planning, trip basics, and corrections all have a clearer home.
      </p>
    </article>

    <aside class="card-surface stack">
      <div>
        <p class="eyebrow">At A Glance</p>
        <h3>Different parts of the trip are covered by different parts of the team.</h3>
      </div>
      <ul class="mini-list">
        <li>{editors.length} named editors write across destination, route, and practical planning coverage.</li>
        <li>{cityDesks.length} city desks maintain destination, district, and place coverage.</li>
        <li>{specialistDesks.length} specialist desks maintain route, readiness, entry, family, and transport coverage.</li>
        <li>{totalPublishedPages} published pages are organized across this editorial structure.</li>
      </ul>
    </aside>
  </section>

  <section class="section-block">
    <h2 class="section-title">How The Desk Structure Works</h2>
    <div class="feature-grid">
      <article class="card-surface">
        <p class="eyebrow">City Coverage</p>
        <h3>Local destination desks</h3>
        <p>City desks handle destination hubs, place pages, neighborhood logic, hotel-area guidance, and city-specific planning guides.</p>
      </article>
      <article class="card-surface">
        <p class="eyebrow">Cross-Country Planning</p>
        <h3>Specialist planning desks</h3>
        <p>Route planning, travel readiness, entry questions, family planning, and transport basics sit separately from local destination storytelling.</p>
      </article>
      <article class="card-surface">
        <p class="eyebrow">Bylines</p>
        <h3>Desk pages show who covers what</h3>
        <p>Desk profiles, published scope, and related policy pages make it easier to follow where different kinds of guidance come from.</p>
      </article>
    </div>
  </section>

  <section class="section-block card-surface">
    <p class="eyebrow">Corrections And Contact</p>
    <h2 class="section-title">How updates and corrections are handled</h2>
    <ul class="mini-list">
      <li>City-specific questions and factual fixes can go to the most relevant destination desk.</li>
      <li>Cross-country planning questions can go to the specialist desk that covers that part of the trip.</li>
      <li>Editorial policy, privacy, and correction requests can also go through the main contact and policy pages.</li>
    </ul>
    <div class="button-row">
      <a class="button-link secondary" href="/contact/">Contact the editors</a>
      <a class="button-link secondary" href="/editorial-policy/">Read editorial policy</a>
    </div>
  </section>

  {specialistDesks.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Specialist Desks</h2>
      <div class="grid two">
        {specialistDesks.map(({ author, articleCount }) => <AuthorCard author={author} articleCount={articleCount} />)}
      </div>
    </section>
  )}

  {editors.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Staff Editors</h2>
      <div class="grid two">
        {editors.map(({ author, articleCount }) => <AuthorCard author={author} articleCount={articleCount} />)}
      </div>
    </section>
  )}

  {cityDesks.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">City Desks</h2>
      <div class="grid two">
        {cityDesks.map(({ author, articleCount }) => <AuthorCard author={author} articleCount={articleCount} />)}
      </div>
    </section>
  )}
</BaseLayout>
