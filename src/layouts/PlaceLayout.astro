---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import CityCard from "../components/CityCard.astro";
import GuideCard from "../components/GuideCard.astro";
import TopicCard from "../components/TopicCard.astro";
import PlaceCard from "../components/PlaceCard.astro";
import PlanningHelpCallout from "../components/PlanningHelpCallout.astro";
import HeroImage from "../components/HeroImage.astro";
import { findAuthorEntry, getAuthorSlug } from "../lib/authors";
import { findCityEntry, getCitySlug } from "../lib/cityEntries";
import { organizationName } from "../lib/site";
import { getPlaceSocialImage } from "../lib/socialImages";

interface Props {
  place: CollectionEntry<"places">;
}

const { place } = Astro.props;
const allCities = await getCollection("cities");
const allGuides = await getCollection("guides", ({ data }) => !data.draft);
const allTopics = await getCollection("topics", ({ data }) => !data.draft);
const allPlaces = await getCollection("places", ({ data }) => !data.draft);
const allAuthors = await getCollection("authors");
const cityHub = findCityEntry(allCities, place.data.city);
const authorEntry = findAuthorEntry(allAuthors, place.data.author);
const relatedGuides = [
  ...place.data.relatedGuideSlugs
    .map((slug) => allGuides.find((guide) => guide.slug === slug))
    .filter(Boolean),
  ...allGuides.filter(
    (guide) =>
      guide.data.city.toLowerCase() === place.data.city.toLowerCase() &&
      !place.data.relatedGuideSlugs.includes(guide.slug),
  ),
].slice(0, 3);
const relatedTopics = [
  ...place.data.relatedTopicSlugs
    .map((slug) => allTopics.find((topic) => topic.slug === slug))
    .filter(Boolean),
  ...allTopics.filter(
    (topic) =>
      topic.data.affectsCities.includes(place.data.city) &&
      !place.data.relatedTopicSlugs.includes(topic.slug),
  ),
].slice(0, 3);
const nearbyPlaces = allPlaces
  .filter((entry) => entry.slug !== place.slug && entry.data.city.toLowerCase() === place.data.city.toLowerCase())
  .slice(0, 3);
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const heroImageUrl = place.data.heroImage ? new URL(place.data.heroImage, siteUrl).href : undefined;
const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Places", href: "/places/" },
  { label: "Destinations", href: "/destinations/" },
  ...(cityHub ? [{ label: cityHub.data.name, href: `/destinations/${getCitySlug(cityHub)}/` }] : []),
  { label: place.data.title },
];
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, siteUrl).href } : { item: canonical }),
  })),
};
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: place.data.title,
  description: place.data.description,
  datePublished: place.data.publishDate.toISOString(),
  dateModified: (place.data.updatedDate ?? place.data.publishDate).toISOString(),
  author: authorEntry
    ? {
        "@type": authorEntry.data.entityType === "organization" ? "Organization" : "Person",
        name: authorEntry.data.name,
        url: new URL(`/authors/${getAuthorSlug(authorEntry)}/`, siteUrl).href,
        description: authorEntry.data.shortBio,
      }
    : {
        "@type": "Person",
        name: place.data.author,
      },
  publisher: {
    "@type": "Organization",
    name: organizationName,
  },
  mainEntityOfPage: canonical,
  ...(heroImageUrl ? { image: [heroImageUrl] } : {}),
  articleSection: "Place Guide",
  keywords: place.data.tags.join(", "),
};
const placeSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  name: place.data.title,
  description: place.data.description,
  url: canonical,
  ...(heroImageUrl ? { image: heroImageUrl } : {}),
  ...(cityHub
    ? {
        touristType: place.data.whoItsFor,
        containedInPlace: {
          "@type": "City",
          name: cityHub.data.name,
        },
      }
    : {}),
};
const faqSchema =
  place.data.faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: place.data.faq.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
          },
        })),
      }
    : undefined;
const pageSchemas = faqSchema
  ? [breadcrumbSchema, articleSchema, placeSchema, faqSchema]
  : [breadcrumbSchema, articleSchema, placeSchema];
const socialImage = getPlaceSocialImage(place);
---

<BaseLayout
  title={place.data.title}
  description={place.data.description}
  socialImage={socialImage}
  type="article"
  publishedTime={place.data.publishDate}
  modifiedTime={place.data.updatedDate}
  schema={pageSchemas}
>
  <section class="split-hero">
    <article class="hero article">
      <div class="article-header">
        <Breadcrumbs items={breadcrumbs} />
        <p class="eyebrow">Place Guide</p>
        <h1>{place.data.title}</h1>
        <p>{place.data.description}</p>
        <p class="meta-row">
          By {authorEntry ? <a href={`/authors/${getAuthorSlug(authorEntry)}/`}>{place.data.author}</a> : place.data.author}
          {" · "}Published {place.data.publishDate.toLocaleDateString("en-US")}
          {place.data.updatedDate && ` · Updated ${place.data.updatedDate.toLocaleDateString("en-US")}`}
        </p>
        {place.data.tags.length > 0 && (
          <ul class="tag-list">
            {place.data.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        )}
      </div>
    </article>

    <aside class="card-surface stack">
      <div>
        <p class="eyebrow">Why Read This</p>
        <h3>Use this before one place becomes the part of the day that breaks the plan.</h3>
      </div>
      {place.data.whoItsFor.length > 0 && (
        <p><strong>Best for:</strong> {place.data.whoItsFor.join(", ")}</p>
      )}
      {cityHub && (
        <p><strong>City hub:</strong> <a href={`/destinations/${getCitySlug(cityHub)}/`}>{cityHub.data.name}</a></p>
      )}
      <ul class="mini-list">
        {place.data.beforeYouGoChecklist.slice(0, 4).map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </aside>
  </section>

  {place.data.heroImage && (
    <section class="section-block">
      <HeroImage
        src={place.data.heroImage}
        alt={place.data.heroImageAlt ?? place.data.title}
        attributionName={place.data.heroImageAttributionName}
        attributionUrl={place.data.heroImageAttributionUrl}
        license={place.data.heroImageLicense}
      />
    </section>
  )}

  <section class="section-block card-surface">
    <p class="eyebrow">Part Of The Cluster</p>
    <h2 class="section-title">Keep this place inside the wider city plan.</h2>
    <p class="muted">
      The strongest place pages help travelers decide how much time to give a place, what to book early, and how to
      connect it back to the city route instead of treating it like an isolated checklist stop.
    </p>
    <div class="button-row">
      {cityHub && <a class="button-link primary" href={`/destinations/${getCitySlug(cityHub)}/`}>Open {cityHub.data.name} hub</a>}
      <a class="button-link secondary" href="/places/">Browse places index</a>
    </div>
  </section>

  <article class="article section-block">
    {place.data.keyTakeaways.length > 0 && (
      <section class="section-block card-surface">
        <h2 class="section-title">Key Takeaways</h2>
        <ul class="mini-list">
          {place.data.keyTakeaways.map((takeaway) => <li>{takeaway}</li>)}
        </ul>
      </section>
    )}
    <slot />
    {place.data.beforeYouGoChecklist.length > 0 && (
      <section class="section-block card-surface">
        <h2 class="section-title">Before You Go</h2>
        <ul class="mini-list">
          {place.data.beforeYouGoChecklist.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    )}
    {place.data.faq.length > 0 && (
      <section class="section-block">
        <h2>FAQ</h2>
        {place.data.faq.map((item) => (
          <>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </>
        ))}
      </section>
    )}
  </article>

  {cityHub && (
    <section class="section-block">
      <h2 class="section-title">Destination Hub</h2>
      <div class="grid two">
        <CityCard city={cityHub} />
      </div>
    </section>
  )}

  {nearbyPlaces.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">More In {place.data.city}</h2>
      <div class="grid two">
        {nearbyPlaces.map((entry) => <PlaceCard place={entry} />)}
      </div>
    </section>
  )}

  {relatedGuides.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Related City Guides</h2>
      <div class="grid two">
        {relatedGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </section>
  )}

  {relatedTopics.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Related Practical Topics</h2>
      <div class="grid two">
        {relatedTopics.map((topic) => <TopicCard topic={topic} />)}
      </div>
    </section>
  )}

  <PlanningHelpCallout
    title={`Need help fitting ${place.data.title} into the trip?`}
    description="If the place matters, but the timing, booking order, or surrounding city day still feels fuzzy, this is a good point for a light planning check."
    primaryLabel="Open plan help"
    primaryHref="/plan-help/"
    secondaryLabel={cityHub ? `Browse ${cityHub.data.name} hub` : "Browse guides"}
    secondaryHref={cityHub ? `/destinations/${getCitySlug(cityHub)}/` : "/guides/"}
    bullets={[
      "Best when one anchor sight is controlling the whole city day.",
      "Useful for timing, hotel-area fit, and surrounding logistics.",
      "A good handoff point before you lock tickets and transport.",
    ]}
  />

  {authorEntry && (
    <section class="section-block card-surface">
      <p class="eyebrow">About The Author</p>
      <h2 class="section-title">{authorEntry.data.name}</h2>
      <p><strong>{authorEntry.data.role}</strong></p>
      <p>{authorEntry.data.fullBio}</p>
      {authorEntry.data.expertise.length > 0 && (
        <ul class="tag-list">
          {authorEntry.data.expertise.map((item) => <li>{item}</li>)}
        </ul>
      )}
      <div class="button-row">
        <a class="button-link primary" href={`/authors/${getAuthorSlug(authorEntry)}/`}>Open author page</a>
        <a class="button-link secondary" href="/authors/">Browse authors</a>
      </div>
    </section>
  )}
</BaseLayout>
