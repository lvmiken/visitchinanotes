---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { defaultContactEmail } from "../../lib/site";

const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL || defaultContactEmail;

const reasons = [
  "Ask a general question about using the site or finding the right planning page.",
  "Report a factual correction, outdated detail, or broken link.",
  "Ask about editorial collaboration, partnerships, or advertising-related inquiries.",
  "Raise a privacy, data, or compliance question related to the site.",
];

const expectations = [
  "Messages are reviewed manually, not by an instant support desk.",
  "Editorial, correction, privacy, and partnership questions may be routed to the most relevant desk before reply.",
  "If the question depends on official transport, ticketing, visa, or attraction rules, official sources should still be treated as final.",
];

const editorialContacts = [
  "Destination-desk questions about city coverage, districts, and route logic.",
  "Corrections or update requests for transport, payment, and booking-basics pages.",
  "Publication or advertising inquiries that need an editorial reply rather than an automated form flow.",
];
---

<BaseLayout
  title="Contact China Travel Notes | General, Editorial, and Privacy Questions"
  description="Contact China Travel Notes for general site questions, editorial corrections, privacy requests, or partnership inquiries."
  showAds={false}
>
  <section class="split-hero">
    <article class="hero article">
      <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Contact" }]} />
      <p class="eyebrow">Contact</p>
      <h1>Get in touch about corrections, partnerships, privacy, or general site questions.</h1>
      <p>
        If you need to reach the team about the content, a privacy question, a partnership idea, or a general site
        issue, use the contact route below.
      </p>
      <div class="button-row">
        {contactEmail ? (
          <a class="button-link primary" href={`mailto:${contactEmail}`}>
            Email {contactEmail}
          </a>
        ) : (
          <a class="button-link primary" href="/masthead/">View masthead</a>
        )}
        {!contactEmail && <a class="button-link secondary" href="/authors/">Browse editors and desks</a>}
        <a class="button-link secondary" href="/privacy/">Read the Privacy Policy</a>
      </div>
    </article>

    <aside class="card-surface stack">
      <div>
        <p class="eyebrow">Best Use</p>
        <h3>This page is for editorial or broader site questions, not a single travel decision.</h3>
      </div>
      <ul class="mini-list">
        <li>Content corrections and factual updates.</li>
        <li>Privacy, cookie, or compliance questions.</li>
        <li>Partnership or advertising-related outreach.</li>
      </ul>
    </aside>
  </section>

  <section class="section-block">
    <h2 class="section-title">What To Contact Us About</h2>
    <div class="feature-grid">
      {reasons.map((item) => (
        <article class="card-surface">
          <p>{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block card-surface">
    <p class="eyebrow">Editorial Routing</p>
    <h2 class="section-title">How messages are routed</h2>
    <ul class="mini-list">
      {editorialContacts.map((item) => <li>{item}</li>)}
    </ul>
    <div class="button-row">
      <a class="button-link secondary" href="/masthead/">View masthead</a>
      <a class="button-link secondary" href="/authors/">Browse editors and desks</a>
      <a class="button-link secondary" href="/editorial-policy/">Read editorial policy</a>
    </div>
  </section>

  <section class="section-block card-surface">
    <p class="eyebrow">Email</p>
    <h2 class="section-title">Primary Contact Method</h2>
    <p>
      {contactEmail
        ? <>The main contact address for this site is <a href={`mailto:${contactEmail}`}>{contactEmail}</a>.</>
        : "Corrections, privacy questions, and partnership inquiries are handled through the shared editorial inbox. Use the masthead, editors page, and policy pages here to find the clearest route."}
    </p>
    <p>
      If you are writing about privacy or personal-data handling, include enough detail to identify the request clearly
      without sending unnecessary sensitive information.
    </p>
  </section>

  <section class="section-block card-surface">
    <p class="eyebrow">Before Sending</p>
    <h2 class="section-title">What To Expect</h2>
    <ul class="mini-list">
      {expectations.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="section-block card-surface">
    <p class="eyebrow">Related Pages</p>
    <h2 class="section-title">Useful pages</h2>
    <div class="button-row">
      <a class="button-link secondary" href="/about/">About</a>
      <a class="button-link secondary" href="/masthead/">Masthead</a>
      <a class="button-link secondary" href="/privacy/">Privacy</a>
      <a class="button-link secondary" href="/editorial-policy/">Editorial Policy</a>
      <a class="button-link secondary" href="/plan-help/">Plan Help</a>
      <a class="button-link secondary" href="/contribute/">Contribute</a>
    </div>
  </section>
</BaseLayout>
