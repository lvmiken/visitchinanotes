---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CityCard from "../components/CityCard.astro";
import GuideCard from "../components/GuideCard.astro";
import TopicCard from "../components/TopicCard.astro";
import TopicClusterCard from "../components/TopicClusterCard.astro";
import { destinationGroups } from "../lib/destinationGroups";
import { topicClusters } from "../lib/topicClusters";

const cities = await getCollection("cities");
const guides = (await getCollection("guides", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const topics = (await getCollection("topics", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const groupedCities = destinationGroups
  .map((group) => ({
    ...group,
    cities: cities.filter((city) => city.data.homepageGroups.includes(group.id)),
  }))
  .filter((group) => group.cities.length > 0);

const planningSteps = [
  {
    title: "Choose the right first-stop city",
    description: "Start with cities that fit your trip length and confidence level rather than collecting every famous place at once.",
  },
  {
    title: "Solve the practical basics first",
    description: "Payments, rail travel, neighborhood choice, and pacing usually matter more than squeezing in one extra attraction.",
  },
  {
    title: "Lock in a route that still feels comfortable",
    description: "The strongest first trips leave room for transport time, weather changes, and a slower day when you need one.",
  },
];

const spotlightCities = destinationGroups
  .map((group) => cities.find((city) => city.data.homepageGroups.includes(group.id)))
  .filter(Boolean)
  .slice(0, 3);
---

<BaseLayout
  title="China Travel Notes | Practical Guides for First-Time Visitors"
  description="English travel guides for visitors planning a trip to China, with city advice, transport basics, and payment tips."
>
  <section class="split-hero">
    <div class="hero">
      <p class="eyebrow">China Travel Planning</p>
      <h1>Help first-time visitors plan China with confidence, not with content overload.</h1>
      <p>
        Explore city ideas, practical trip basics, and planning guides designed for travelers who want a smoother
        first trip to China.
      </p>
      <div class="button-row">
        <a class="button-link primary" href="/destinations/">Explore destinations</a>
        <a class="button-link secondary" href="/topics/">Read trip basics</a>
      </div>
      <div class="pill-row">
        <span>Destination hubs</span>
        <span>Trip basics</span>
        <span>First-time itineraries</span>
      </div>
    </div>

    <aside class="card-surface stack">
      <div>
        <p class="eyebrow">Start Here</p>
        <h3>Start with the decisions that make the rest of the trip easier.</h3>
        <p class="muted">
          If this is your first China trip, the easiest path is usually to choose a suitable city, solve the practical
          basics, and only then shape the day-by-day plan.
        </p>
      </div>
      <ul class="mini-list">
        <li>Start with cities that fit your route and travel style.</li>
        <li>Answer practical questions before they become travel stress.</li>
        <li>Keep each next click useful and easy to understand.</li>
      </ul>
    </aside>
  </section>

  <section class="section-block">
    <h2 class="section-title">How Most First-Time Travelers Decide</h2>
    <div class="feature-grid">
      {planningSteps.map((step) => (
        <article class="card-surface">
          <p class="eyebrow">Step</p>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block card-surface">
    <p class="eyebrow">Plan At A Glance</p>
    <h2 class="section-title">Start with a city, then move into practical trip questions and route details.</h2>
    <div class="stat-grid">
      <div>
        <strong>{cities.length}</strong>
        <span class="muted">cities to compare</span>
      </div>
      <div>
        <strong>{topics.length}</strong>
        <span class="muted">trip basics to read first</span>
      </div>
      <div>
        <strong>{guides.length}</strong>
        <span class="muted">planning guides to explore</span>
      </div>
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">Featured Destinations</h2>
    <p class="muted">Browse by trip style first, then drill into the city that fits your pace, route, and interests.</p>
    <div class="stack">
      {groupedCities.map((group) => (
        <section class="card-surface">
          <h3>{group.title}</h3>
          <p class="muted">{group.description}</p>
          <div class="grid three">
            {group.cities.map((city) => <CityCard city={city} />)}
          </div>
        </section>
      ))}
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">Example City Angles</h2>
    <div class="feature-grid">
      {spotlightCities.map((city) => (
        <article class="card-surface">
          <p class="eyebrow">{city.data.name}</p>
          <h3>Best for {city.data.idealFor[0] ?? "first-time visitors"}</h3>
          <p class="muted">Suggested stay: {city.data.suggestedStay}</p>
          <p>{city.data.transportNote}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">Planning Hubs</h2>
    <p class="muted">Start with a topic hub if the trip problem is clearer than the destination, such as arrival, transport, payments, or route shape.</p>
    <div class="grid two">
      {topicClusters.map((cluster) => <TopicClusterCard cluster={cluster} />)}
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">Practical Trip Topics</h2>
    <p class="muted">These are the planning questions many travelers search before they even settle on a final route.</p>
    <div class="grid two">
      {topics.slice(0, 4).map((topic) => <TopicCard topic={topic} />)}
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">Planning Guides</h2>
    <p class="muted">Use guide pages to answer specific city, itinerary, and stay-planning questions with clear next reads.</p>
    <div class="grid two">
      {guides.slice(0, 6).map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>
</BaseLayout>
