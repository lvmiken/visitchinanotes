---
import type { CollectionEntry } from "astro:content";
import { guideStageMap } from "../lib/guideStages";
import { slugifyAuthorValue } from "../lib/authors";

interface Props {
  guide: CollectionEntry<"guides">;
}

const { guide } = Astro.props;
const cityLabel = guide.data.tags[0] ?? guide.data.city;
const stageLabel = guideStageMap[guide.data.guideStage]?.label ?? "Travel Guide";
const authorSlug = slugifyAuthorValue(guide.data.author);
---

<article class="card">
  <p class="eyebrow">{cityLabel}</p>
  <h3>
    <a href={`/guides/${guide.slug}/`}>{guide.data.title}</a>
  </h3>
  <p>{guide.data.description}</p>
  <p class="meta">{stageLabel}{guide.data.tripLength ? ` · ${guide.data.tripLength}` : ""}</p>
  <p class="meta">By <a class="meta-link" href={`/authors/${authorSlug}/`}>{guide.data.author}</a></p>
  <p class="meta">
    Updated {guide.data.updatedDate ? guide.data.updatedDate.toLocaleDateString("en-US") : guide.data.publishDate.toLocaleDateString("en-US")}
  </p>
</article>

<style>
  .card {
    padding: 1.25rem;
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    background: #fff;
  }

  .eyebrow,
  .meta {
    margin: 0;
    color: #6b7280;
    font-size: 0.9rem;
  }

  h3 {
    margin: 0.5rem 0;
    font-size: 1.2rem;
  }

  a {
    color: #111827;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  .meta-link {
    color: inherit;
  }
</style>
