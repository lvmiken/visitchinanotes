---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CityCard from "../components/CityCard.astro";
import GuideCard from "../components/GuideCard.astro";
import TopicCard from "../components/TopicCard.astro";
import TopicClusterCard from "../components/TopicClusterCard.astro";
import PlaceCard from "../components/PlaceCard.astro";
import AuthorCard from "../components/AuthorCard.astro";
import { destinationGroups } from "../lib/destinationGroups";
import { topicClusters } from "../lib/topicClusters";
import { getAuthorSlug } from "../lib/authors";

const cities = await getCollection("cities");
const authors = await getCollection("authors");
const guides = (await getCollection("guides", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const topics = (await getCollection("topics", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const places = (await getCollection("places", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const highIntentTopicSlugs = [
  "can-tourists-use-alipay-in-china",
  "can-tourists-use-wechat-pay-in-china",
  "best-esim-for-china",
  "how-to-use-didi-in-china",
  "do-you-need-a-vpn-in-china",
  "how-to-book-forbidden-city-tickets",
  "book-high-speed-train",
  "12306-for-foreigners",
  "how-to-ride-china-high-speed-rail",
  "how-to-book-terracotta-warriors-tickets",
];
const highIntentTopics = highIntentTopicSlugs
  .map((slug) => topics.find((topic) => topic.slug === slug))
  .filter(Boolean);
const highIntentGuideSlugs = [
  "beijing-where-to-stay",
  "beijing-xian-or-shanghai-pairing",
  "shanghai-airport-to-city",
  "chengdu-tianfu-airport-to-city",
  "chongqing-where-to-stay",
  "shaanxi-history-museum-or-xian-museum",
];
const highIntentGuides = highIntentGuideSlugs
  .map((slug) => guides.find((guide) => guide.slug === slug))
  .filter(Boolean);
const editorialFeatureConfigs = [
  {
    slug: "beijing-fast-and-slow-where-ancient-souls-and-high-tech-comforts-actually-meet",
    desk: "From The Beijing Desk",
    sectionTitle: "A stronger first impression of China often begins with the Beijing that feels lived, not only monumental.",
    intro:
      "This feature explains why Beijing feels richest when imperial scale, hutong life, park culture, food routines, and digital convenience are read together instead of as separate tourist boxes.",
    bullets: [
      "Pairs micro city observation with practical visitor advice.",
      "Pushes beyond the usual Beijing landmark checklist.",
      "Brings together observation, local texture, and practical trip advice in one piece.",
    ],
    hubHref: "/destinations/beijing/",
    hubLabel: "Open Beijing hub",
  },
  {
    slug: "shanghai-the-liquid-city-where-haipai-life-still-feels-alive",
    desk: "From The Shanghai Desk",
    sectionTitle: "Shanghai becomes far more memorable when the skyline is only one layer of a city built on Haipai coexistence.",
    intro:
      "This feature uses architecture, longtang life, coffee culture, Suzhou Creek, and nighttime social rituals to explain why Shanghai works so well as both a soft landing and a culturally serious city.",
    bullets: [
      "Explains Shanghai through Haipai culture instead of skyline clichés alone.",
      "Connects style, food, architecture, and local routines in one narrative.",
      "Shows how a city can feel stylish, practical, and deeply local at the same time.",
    ],
    hubHref: "/destinations/shanghai/",
    hubLabel: "Open Shanghai hub",
  },
  {
    slug: "chengdu-the-underground-oasis-where-anyi-and-youth-culture-still-share-the-same-streets",
    desk: "From The Chengdu Desk",
    sectionTitle: "Chengdu feels most revealing when tea-house calm, Yulin street life, youth style, and softer forms of self-expression are read together.",
    intro:
      "This feature explains why Chengdu means far more than pandas and hotpot, using anyi, neighborhood culture, queer-friendly ease, cafes, and music scenes to show the city as a real contemporary refuge for younger travelers.",
    bullets: [
      "Pushes Chengdu beyond panda-and-food stereotypes into a fuller social portrait.",
      "Brings out a fuller city voice while still connecting into practical planning pages.",
      "Gives readers a more observed and human picture of how the city actually feels.",
    ],
    hubHref: "/destinations/chengdu/",
    hubLabel: "Open Chengdu hub",
  },
  {
    slug: "chongqing-the-cyber-grit-on-the-yangtze-where-vertical-space-and-jianghu-still-shape-the-city",
    desk: "From The Chongqing Desk",
    sectionTitle: "Chongqing becomes much more than a viral 3D city once its vertical space, industrial afterlife, food heat, and rough human energy are read together.",
    intro:
      "This feature moves beyond cyberpunk photo clichés to explain why Chongqing feels so physically intense, using impossible levels, bomb shelters, river-city pressure, and jianghu temperament to give the city a stronger editorial identity.",
    bullets: [
      "Pushes Chongqing beyond skyline spectacle into industrial, social, and cultural depth.",
      "Connects viral visual hooks to harder realities such as terrain, labor, and bunker reuse.",
      "Shows why the city feels so intense once landscape, labor, and daily life are read together.",
    ],
    hubHref: "/destinations/chongqing/",
    hubLabel: "Open Chongqing hub",
  },
  {
    slug: "qingdao-ocean-foam-and-old-european-ghosts-where-coastal-romance-still-feels-local",
    desk: "From The Qingdao Desk",
    sectionTitle: "Qingdao feels richest when German-era silhouettes, bagged draft beer, seafood appetite, and sea-facing slowness are read as one coastal culture.",
    intro:
      "This feature pushes Qingdao beyond the Tsingtao bottle image, using old villas, red roofs, local beer rituals, seafood life, and Laoshan's mountain-and-sea contrast to give the city a softer but highly specific editorial identity.",
    bullets: [
      "Shows Qingdao as more than a light add-on, with a clearer sense of mood, ritual, and place.",
      "Connects architecture, beer, seafood, and coastal pacing without falling into brochure language.",
      "Gives Qingdao a clearer editorial identity built from mood, ritual, and place.",
    ],
    hubHref: "/destinations/qingdao/",
    hubLabel: "Open Qingdao hub",
  },
  {
    slug: "xian-the-dust-the-subterranean-and-the-punk-symphony-where-history-refuses-to-stay-buried",
    desk: "From The Xi'an Desk",
    sectionTitle: "Xi'an feels most revealing when imperial gravity, food ritual, archaeology, and neon historical performance are allowed to collide without being cleaned up.",
    intro:
      "This feature pushes Xi'an beyond Terracotta Army shorthand, using walls, paomo, buried history, and Tang-themed night culture to show the city as one of China's most surreal and physically grounded urban experiences.",
    bullets: [
      "Turns Xi'an from a schoolbook history stop into a living, rough-edged editorial city portrait.",
      "Connects archaeology, food, old-city pacing, and contemporary spectacle in one durable narrative.",
      "Shows why Xi'an feels alive when history, appetite, and street life are allowed to collide.",
    ],
    hubHref: "/destinations/xian/",
    hubLabel: "Open Xi'an hub",
  },
  {
    slug: "guangzhou-the-subtropical-underground-where-wok-hei-and-low-fi-life-still-rule",
    desk: "From The Guangzhou Desk",
    sectionTitle: "Guangzhou feels most revealing when food heat, trade routes, low-fi street life, and anti-pretentious style are read as one southern urban ecosystem.",
    intro:
      "This feature pushes Guangzhou beyond Canton Fair shorthand, using urban-village logic, Dongshankou style, Xiaobei's grassroots globalism, Pearl River nights, and wok hei to show why the city often feels freer than its official image suggests.",
    bullets: [
      "Turns Guangzhou from a practical food stop into a full editorial portrait with social texture.",
      "Connects trade, migration, appetite, and street style without relying on brittle venue-driven hype.",
      "Shows how Guangzhou's appetite, trade energy, and street life create a city with its own rhythm.",
    ],
    hubHref: "/destinations/guangzhou/",
    hubLabel: "Open Guangzhou hub",
  },
];
const editorialFeatures = editorialFeatureConfigs
  .map((config) => {
    const guide = guides.find((entry) => entry.slug === config.slug);
    return guide ? { ...config, guide } : undefined;
  })
  .filter(Boolean);

const groupedCities = destinationGroups
  .map((group) => ({
    ...group,
    cities: cities.filter((city) => city.data.homepageGroups.includes(group.id)),
  }))
  .filter((group) => group.cities.length > 0);

const planningSteps = [
  {
    title: "Choose the right first-stop city",
    description: "Start with cities that fit your trip length and confidence level rather than collecting every famous place at once.",
  },
  {
    title: "Solve the practical basics first",
    description: "Payments, rail travel, neighborhood choice, and pacing usually matter more than squeezing in one extra attraction.",
  },
  {
    title: "Lock in a route that still feels comfortable",
    description: "The strongest first trips leave room for transport time, weather changes, and a slower day when you need one.",
  },
];

const spotlightCities = destinationGroups
  .map((group) => cities.find((city) => city.data.homepageGroups.includes(group.id)))
  .filter(Boolean)
  .slice(0, 3);
const featuredPlaceSlugs = [
  "forbidden-city",
  "mutianyu-great-wall",
  "the-bund",
  "french-concession",
  "terracotta-army",
  "xian-city-wall",
];
const featuredPlaces = featuredPlaceSlugs
  .map((slug) => places.find((place) => place.slug === slug))
  .filter(Boolean);
const featuredDeskIds = [
  "beijing-desk",
  "shanghai-desk",
  "xian-desk",
  "route-planning-desk",
  "travel-readiness-desk",
  "entry-and-visa-desk",
  "family-travel-desk",
  "transport-and-payments-desk",
];
const featuredDesks = featuredDeskIds
  .map((id) => authors.find((author) => author.id === id))
  .filter(Boolean);
const deskCount = authors.filter((author) => author.id !== "editorial-team").length;
const specialistDeskCount = [
  "route-planning-desk",
  "travel-readiness-desk",
  "entry-and-visa-desk",
  "family-travel-desk",
  "transport-and-payments-desk",
].filter((id) => authors.some((author) => author.id === id)).length;
const trustLinks = [
  { label: "About the publication", href: "/about/" },
  { label: "Publication masthead", href: "/masthead/" },
  { label: "Editorial policy", href: "/editorial-policy/" },
  { label: "Editors and desks", href: "/authors/" },
  { label: "Contact the editors", href: "/contact/" },
];
---

<BaseLayout
  title="China Travel Notes | Practical Guides for First-Time Visitors"
  description="English travel guides for visitors planning a trip to China, with city advice, transport basics, and payment tips."
>
  <section class="split-hero">
    <div class="hero">
      <p class="eyebrow">China Travel Planning</p>
      <h1>Help first-time visitors plan China with confidence, not with content overload.</h1>
      <p>
        Explore city ideas, practical trip basics, and planning guides designed for travelers who want a smoother
        first trip to China.
      </p>
      <div class="button-row">
        <a class="button-link primary" href="/destinations/">Explore destinations</a>
        <a class="button-link secondary" href="/topics/">Read trip basics</a>
      </div>
      <div class="pill-row">
        <span>Destination hubs</span>
        <span>Trip basics</span>
        <span>First-time itineraries</span>
        <span>Places worth planning</span>
      </div>
    </div>

    <aside class="card-surface stack">
      <div>
        <p class="eyebrow">Start Here</p>
        <h3>Start with the decisions that make the rest of the trip easier.</h3>
        <p class="muted">
          If this is your first China trip, the easiest path is usually to choose a suitable city, solve the practical
          basics, and only then shape the day-by-day plan.
        </p>
      </div>
      <ul class="mini-list">
        <li>Start with cities that fit your route and travel style.</li>
        <li>Answer practical questions before they become travel stress.</li>
        <li>Keep each next click useful and easy to understand.</li>
      </ul>
    </aside>
  </section>

  {editorialFeatures.length > 0 && (
    <section class="section-block">
      <p class="eyebrow">Editorial Features</p>
      <h2 class="section-title">Longer city features that bring mood, culture, and lived detail into the trip-planning picture.</h2>
      <div class="stack">
        {editorialFeatures.map((feature) => (
          <section class="card-surface">
            <p class="eyebrow">{feature.desk}</p>
            <h3>{feature.sectionTitle}</h3>
            <p class="muted">{feature.intro}</p>
            <div class="grid two" style="align-items: start;">
              <GuideCard guide={feature.guide} />
              <article class="card-surface">
                <p class="eyebrow">Why Read It</p>
                <h3>It adds context, judgment, and a stronger sense of place.</h3>
                <ul class="mini-list">
                  {feature.bullets.map((item) => <li>{item}</li>)}
                </ul>
                <div class="button-row">
                  <a class="button-link primary" href={`/guides/${feature.guide.slug}/`}>Read the feature</a>
                  <a class="button-link secondary" href={feature.hubHref}>{feature.hubLabel}</a>
                </div>
              </article>
            </div>
          </section>
        ))}
      </div>
    </section>
  )}

  <section class="section-block">
    <h2 class="section-title">How Most First-Time Travelers Decide</h2>
    <div class="feature-grid">
      {planningSteps.map((step) => (
        <article class="card-surface">
          <p class="eyebrow">Step</p>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block card-surface">
    <p class="eyebrow">Plan At A Glance</p>
    <h2 class="section-title">Start with a city, then move into practical trip questions and route details.</h2>
    <div class="stat-grid">
      <div>
        <strong>{cities.length}</strong>
        <span class="muted">cities to compare</span>
      </div>
      <div>
        <strong>{topics.length}</strong>
        <span class="muted">trip basics to read first</span>
      </div>
      <div>
        <strong>{guides.length}</strong>
        <span class="muted">planning guides to explore</span>
      </div>
      <div>
        <strong>{places.length}</strong>
        <span class="muted">place guides in the library</span>
      </div>
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">Editorial Coverage</h2>
    <p class="muted">
      China Travel Notes is organized around named editors, city desks, and specialist planning desks so readers can move between destination ideas, route design, entry questions, family planning, and trip basics with clearer guidance.
    </p>
    <div class="feature-grid">
      <article class="card-surface">
        <p class="eyebrow">Desk Network</p>
        <h3>{deskCount} active editorial desks</h3>
        <p>Coverage is split across city desks and {specialistDeskCount} specialist desks instead of relying on one undifferentiated author pool.</p>
      </article>
      <article class="card-surface">
        <p class="eyebrow">Review Model</p>
        <h3>Different travel questions are handled through different desks</h3>
        <p>City pages, place pages, and route guides sit alongside specialist coverage for transport, readiness, visa, and family travel, so each topic can be approached with the right kind of focus.</p>
      </article>
      <article class="card-surface">
        <p class="eyebrow">Reader Trust</p>
        <h3>Readers can see who stands behind the advice</h3>
        <p>Desk profiles, editorial standards, and contact routes make it easier to understand how the site is organized and where each kind of guidance comes from.</p>
      </article>
    </div>
    {featuredDesks.length > 0 && (
      <div class="grid two" style="margin-top: 1.5rem;">
        {featuredDesks.map((author) => <AuthorCard author={author} articleCount={0} />)}
      </div>
    )}
    <div class="button-row">
      <a class="button-link secondary" href="/authors/">Browse all editors and desks</a>
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">Featured Destinations</h2>
    <p class="muted">Browse by trip style first, then drill into the city that fits your pace, route, and interests.</p>
    <div class="stack">
      {groupedCities.map((group) => (
        <section class="card-surface">
          <h3>{group.title}</h3>
          <p class="muted">{group.description}</p>
          <div class="grid three">
            {group.cities.map((city) => <CityCard city={city} />)}
          </div>
        </section>
      ))}
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">Example City Angles</h2>
    <div class="feature-grid">
      {spotlightCities.map((city) => (
        <article class="card-surface">
          <p class="eyebrow">{city.data.name}</p>
          <h3>Best for {city.data.idealFor[0] ?? "first-time visitors"}</h3>
          <p class="muted">Suggested stay: {city.data.suggestedStay}</p>
          <p>{city.data.transportNote}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">Planning Hubs</h2>
    <p class="muted">Start with a topic hub if the trip problem is clearer than the destination, such as arrival, transport, payments, or route shape.</p>
    <div class="grid two">
      {topicClusters.map((cluster) => <TopicClusterCard cluster={cluster} />)}
    </div>
  </section>

  {featuredPlaces.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Places Worth Planning Around</h2>
      <p class="muted">These are the landmark, neighborhood, and museum pages that most often help travelers build fuller city days.</p>
      <div class="button-row" style="margin-top: 0;">
        <a class="button-link secondary" href="/places/">Open places index</a>
      </div>
      <div class="grid two">
        {featuredPlaces.map((place) => <PlaceCard place={place} />)}
      </div>
    </section>
  )}

  <section class="section-block">
    <h2 class="section-title">High-Intent Planning Topics</h2>
    <p class="muted">These pages target the practical questions travelers often search before bookings start to feel safe.</p>
    <div class="grid two">
      {highIntentTopics.map((topic) => <TopicCard topic={topic} />)}
    </div>
  </section>

  {highIntentGuides.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Popular Planning Guides</h2>
      <p class="muted">These are the city-specific questions travelers often search once the trip starts becoming real.</p>
      <div class="grid two">
        {highIntentGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </section>
  )}

  <section class="section-block">
    <h2 class="section-title">Planning Guides</h2>
    <p class="muted">Use guide pages to answer specific city, itinerary, and stay-planning questions with clear next reads.</p>
    <div class="grid two">
      {guides.slice(0, 6).map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>

  <section class="section-block card-surface">
    <p class="eyebrow">Publication Basics</p>
    <h2 class="section-title">Know who publishes the advice and how to verify it.</h2>
    <div class="button-row">
      {trustLinks.map((item) => (
        <a class="button-link secondary" href={item.href}>{item.label}</a>
      ))}
    </div>
  </section>
</BaseLayout>
