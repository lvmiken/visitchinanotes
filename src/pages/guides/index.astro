---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GuideCard from "../../components/GuideCard.astro";
import { guideStages } from "../../lib/guideStages";

const guides = (await getCollection("guides", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const groupedGuides = guideStages
  .map((stage) => ({
    ...stage,
    guides: guides.filter((guide) => guide.data.guideStage === stage.id),
  }))
  .filter((group) => group.guides.length > 0);
---

<BaseLayout
  title="China Travel Guides for First-Time Visitors | Itineraries, Where to Stay, Airports, and Tips"
  description="Browse China travel guides on where to stay, how many days to plan, airport transfers, trains, payments, and city itineraries for first-time visitors."
>
  <section class="hero article">
    <p class="eyebrow">Guide Index</p>
    <h1>Use these guides when you are choosing where to stay, how long to go, and what to prioritize.</h1>
    <p>
      Browse destination guides, itinerary ideas, and practical planning articles that help turn general interest into
      a workable route.
    </p>
  </section>

  <section class="section-block stack">
    {groupedGuides.map((group) => (
      <section class="card-surface">
        <h2 class="section-title">{group.label}</h2>
        <p class="muted">{group.description}</p>
        <div class="grid two">
          {group.guides.map((guide) => <GuideCard guide={guide} />)}
        </div>
      </section>
    ))}
  </section>
</BaseLayout>
