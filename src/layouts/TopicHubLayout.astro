---
import { getCollection } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import TopicCard from "../components/TopicCard.astro";
import CityCard from "../components/CityCard.astro";
import PlanningHelpCallout from "../components/PlanningHelpCallout.astro";
import { findCityEntry, uniqueCityEntries } from "../lib/cityEntries";
import { getTopicsForCluster, topicClusterMap } from "../lib/topicClusters";

interface Props {
  clusterId: keyof typeof topicClusterMap;
}

const { clusterId } = Astro.props;
const cluster = topicClusterMap[clusterId];
const allTopics = await getCollection("topics", ({ data }) => !data.draft);
const clusterTopics = getTopicsForCluster(cluster, allTopics);
const allCities = await getCollection("cities");
const relatedCities = uniqueCityEntries(
  clusterTopics.flatMap((topic) =>
    topic.data.affectsCities.map((cityName) => findCityEntry(allCities, cityName)),
  ),
).slice(0, 6);
const quickStartTopics = (cluster.quickStartTopicSlugs ?? cluster.topicSlugs.slice(0, 3))
  .map((slug) => allTopics.find((topic) => topic.slug === slug))
  .filter(Boolean);
---

<BaseLayout
  title={`${cluster.title} | China Trip Topic Hub`}
  description={cluster.description}
  showAds={false}
>
  <section class="split-hero">
    <div class="hero article">
      <p class="eyebrow">Topic Hub</p>
      <h1>{cluster.heroTitle ?? cluster.title}</h1>
      <p>{cluster.description}</p>
      {cluster.editorialNote && <p class="muted">{cluster.editorialNote}</p>}
      <div class="pill-row">
        <span>{clusterTopics.length} focused reads</span>
        <span>{cluster.whenToUse}</span>
      </div>
    </div>

    <aside class="card-surface stack">
      <div>
        <p class="eyebrow">How To Use This Hub</p>
        <h3>Start here when one planning question begins steering everything else.</h3>
      </div>
      <p class="muted">{cluster.whenToUse}</p>
      <ul class="mini-list">
        {cluster.solveFirst?.map((item) => <li>{item}</li>)}
      </ul>
    </aside>
  </section>

  {quickStartTopics.length > 0 && (
    <section class="section-block card-surface">
      <p class="eyebrow">Quick Start</p>
      <h2 class="section-title">If you want the cleanest path through this subject, begin with these three reads.</h2>
      <div class="feature-grid">
        {quickStartTopics.map((topic, index) => (
          <article class="card-surface">
            <p class="eyebrow">Step {index + 1}</p>
            <h3><a href={`/topics/${topic.slug}/`}>{topic.data.title}</a></h3>
            <p class="muted">{topic.data.whenToRead}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="section-block">
    <h2 class="section-title">Included Topics</h2>
    <p class="muted">Take the quick path above, or move through the full set below if the decision still needs more context.</p>
    <div class="grid two">
      {clusterTopics.map((topic) => <TopicCard topic={topic} />)}
    </div>
  </section>

  {(cluster.solveFirst?.length || cluster.avoidFirst?.length) && (
    <section class="section-block card-surface">
      <p class="eyebrow">Editors&apos; Notes</p>
      <h2 class="section-title">This hub is strongest when it clears one knot instead of creating five smaller ones.</h2>
      <div class="feature-grid">
        {cluster.solveFirst?.length ? (
          <article class="card-surface">
            <p class="eyebrow">Solve First</p>
            <h3>What to settle early.</h3>
            <ul class="mini-list">
              {cluster.solveFirst.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ) : null}
        {cluster.avoidFirst?.length ? (
          <article class="card-surface">
            <p class="eyebrow">Avoid Next</p>
            <h3>What usually makes this subject feel heavier than it is.</h3>
            <ul class="mini-list">
              {cluster.avoidFirst.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ) : null}
      </div>
    </section>
  )}

  {relatedCities.length > 0 && (
    <section class="section-block">
      <h2 class="section-title">Destination Hubs That Pair Well With This Topic</h2>
      <div class="grid two">
        {relatedCities.map((city) => <CityCard city={city} />)}
      </div>
    </section>
  )}

  <PlanningHelpCallout
    title={`Still untangling ${cluster.title.toLowerCase()}?`}
    description="If this question is still holding the route in place, a short planning note can help turn the reading into a decision."
    primaryLabel="Talk through the route"
    primaryHref="/plan-help/"
    secondaryLabel="Browse destination hubs"
    secondaryHref="/destinations/"
    bullets={[
      "Best when the route is partly shaped but one question still keeps it from settling.",
      "Useful for hotel-area choices, pacing checks, or practical next steps.",
      "Keep the note narrow and specific for the clearest answer.",
    ]}
  />
</BaseLayout>
