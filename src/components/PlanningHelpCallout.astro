---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  bullets?: string[];
}

const {
  eyebrow = "Need Help Planning?",
  title,
  description,
  primaryLabel = "Ask For A Route Check",
  primaryHref = "/plan-help/",
  secondaryLabel,
  secondaryHref,
  bullets = [],
} = Astro.props;
---

<section class="section-block planning-help-callout">
  <div class="card-surface split-help">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h2 class="section-title">{title}</h2>
      <p class="muted">{description}</p>
      <div class="button-row">
        <a class="button-link primary" href={primaryHref}>{primaryLabel}</a>
        {secondaryLabel && secondaryHref && (
          <a class="button-link secondary" href={secondaryHref}>{secondaryLabel}</a>
        )}
      </div>
    </div>
    {bullets.length > 0 && (
      <div class="help-bullets">
        <ul class="mini-list">
          {bullets.map((bullet) => <li>{bullet}</li>)}
        </ul>
      </div>
    )}
  </div>
</section>

<style>
  .split-help {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: minmax(0, 1.5fr) minmax(240px, 1fr);
    align-items: center;
    background:
      linear-gradient(135deg, rgba(223, 248, 241, 0.9) 0%, rgba(255, 255, 255, 0.98) 70%),
      #ffffff;
  }

  .help-bullets {
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid var(--border);
  }

  @media (max-width: 720px) {
    .split-help {
      grid-template-columns: 1fr;
    }
  }
</style>
