---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

const workflow = [
  {
    title: "We start from real traveler questions",
    description: "Pages are built around practical search intents such as where to stay, how to pay, how to get from the airport, or how many days to spend, not around filler topics that sound broad but solve little.",
  },
  {
    title: "We prefer useful decisions over generic inspiration",
    description: "The goal is to help readers choose, compare, and avoid mistakes. A page should reduce friction, not just repeat attraction lists or vague travel marketing language.",
  },
  {
    title: "We revise when a page needs to be clearer",
    description: "If transport patterns, booking logic, payment habits, or route advice become stale or too vague, the page should be improved so it stays genuinely helpful for first-time visitors.",
  },
];

const standards = [
  "Prefer clear recommendations, tradeoffs, and next steps over long attraction dumps.",
  "Write for first-time visitors who need practical help in plain English.",
  "Separate editorial advice from any partner or lead-handoff step.",
  "Avoid implying guaranteed prices, availability, approvals, or outcomes.",
];

const readerPromises = [
  {
    title: "Specific questions first",
    description: "We try to make each page answer one concrete planning problem well, so readers can finish with a clearer decision instead of more tabs open.",
  },
  {
    title: "Best-practice travel logic",
    description: "We favor realistic pacing, workable hotel areas, easier transfers, and lower-friction routes over ambitious plans that look good on paper only.",
  },
  {
    title: "Reader value before site goals",
    description: "A page should still be worth reading even if the reader never clicks another link, submits a form, or asks for outside help.",
  },
];
---

<BaseLayout
  title="Editorial Policy | China Travel Notes"
  description="Read the editorial principles behind China Travel Notes, including how the site prioritizes useful travel advice, practical best practices, and reader-first planning help."
  noindex={true}
>
  <section class="split-hero">
    <article class="hero article">
      <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Editorial Policy" }]} />
      <p class="eyebrow">Editorial Policy</p>
      <h1>Useful travel advice should make a China trip easier, not just longer to research.</h1>
      <p>
        China Travel Notes is built for readers who want practical English guidance for planning China with more
        confidence. The standard is simple: a page should help solve a real trip problem, reduce avoidable stress, and
        make the next decision easier.
      </p>
    </article>

    <aside class="card-surface stack">
      <div>
        <p class="eyebrow">Core Rule</p>
        <h3>Helpful beats impressive.</h3>
      </div>
      <p class="muted">
        A shorter page that answers the right question clearly is more valuable than a longer page that sounds complete
        but leaves the reader unsure what to do next.
      </p>
    </aside>
  </section>

  <section class="section-block">
    <h2 class="section-title">What Readers Should Expect</h2>
    <div class="feature-grid">
      {readerPromises.map((item) => (
        <article class="card-surface">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">How Content Is Produced</h2>
    <div class="feature-grid">
      {workflow.map((item) => (
        <article class="card-surface">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block card-surface">
    <p class="eyebrow">Editorial Standards</p>
    <h2 class="section-title">Publishing Rules</h2>
    <ul class="mini-list">
      {standards.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="section-block">
    <h2 class="section-title">How We Judge Whether A Page Is Good Enough</h2>
    <div class="grid two">
      <article class="card-surface">
        <h3>It should answer the practical question directly</h3>
        <p>
          Readers should quickly understand who the page is for, what choice they need to make, what tradeoffs matter,
          and what common mistake to avoid.
        </p>
      </article>
      <article class="card-surface">
        <h3>It should make the wider trip easier</h3>
        <p>
          Good travel content does not only explain one fact. It helps the reader connect that fact to hotel choice,
          transfer ease, route shape, budget, or first-day confidence.
        </p>
      </article>
    </div>
  </section>

  <section class="section-block">
    <h2 class="section-title">Partner Disclosure</h2>
    <div class="grid two">
      <article class="card-surface">
        <h3>Editorial pages are not sales pages</h3>
        <p>
          Destination hubs, guide pages, and topic pages should stand on their own even if the traveler never asks for outside help.
        </p>
      </article>
      <article class="card-surface">
        <h3>Partner introductions are a separate step</h3>
        <p>
          If a traveler asks for booking support or route help, the request may be reviewed first and then shared with a suitable travel partner.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
