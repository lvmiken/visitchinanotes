---
import { topicClusters } from "../lib/topicClusters";

interface Props {
  cluster: (typeof topicClusters)[number];
}

const { cluster } = Astro.props;
---

<article class="topic-cluster-card">
  <div class="card-top">
    <p class="eyebrow">Topic Hub</p>
    <p class="meta">{cluster.topicSlugs.length} focused reads</p>
  </div>
  <h3>
    <a href={`/topics/${cluster.slug}/`}>{cluster.heroTitle ?? cluster.title}</a>
  </h3>
  <p class="kicker">{cluster.title}</p>
  <p>{cluster.description}</p>
  {cluster.solveFirst?.length ? (
    <ul class="mini-list">
      {cluster.solveFirst.slice(0, 2).map((item) => <li>{item}</li>)}
    </ul>
  ) : null}
  <p class="meta">Best read when: {cluster.whenToUse}</p>
</article>

<style>
  .topic-cluster-card {
    display: grid;
    gap: 0.9rem;
    padding: 1.4rem;
    border: 1px solid #d9e0ea;
    border-radius: 1rem;
    background:
      linear-gradient(180deg, rgba(247, 250, 252, 0.96), rgba(255, 255, 255, 1));
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.05);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
  }

  h3 {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.25;
  }

  a {
    color: #111827;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  .kicker {
    margin: -0.35rem 0 0;
    color: #8b5e3c;
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .mini-list {
    margin: 0;
    padding-left: 1.1rem;
    color: #334155;
  }

  .mini-list li + li {
    margin-top: 0.45rem;
  }

  .meta {
    color: #6b7280;
    font-size: 0.92rem;
  }
</style>
